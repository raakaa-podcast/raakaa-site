# Media kit — build-time metrics (optional)
# Aseta nämä Netlifyssa: Site configuration → Environment variables
# Arvot haetaan jokaisen `npm run build` / deployn aikana.

# Yksi JSON-endpoint, josta luetaan alustaluvut (GET, application/json).
# Voi olla esim. oma Cloud Function, Gist (raw), tai sisäinen metrics-API.
MEDIAKIT_METRICS_URL=
MEDIAKIT_METRICS_TOKEN=

# Vaihtoehtoisesti / täydennykseksi suoraan numeroina (endpointin puuttuessa tai puuttuvien kenttien täyttöön):
MEDIAKIT_SPOTIFY_FOLLOWERS=
MEDIAKIT_SPOTIFY_MONTHLY_LISTENERS=
MEDIAKIT_YOUTUBE_SUBSCRIBERS=
MEDIAKIT_YOUTUBE_VIEWS=
MEDIAKIT_APPLE_RATING=
MEDIAKIT_APPLE_RATINGS_COUNT=
