---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Tilaus vahvistettu | RAAKAA Podcast"
  description="Kiitos tilauksesta. Saat sähköpostiin viestin aina uuden jakson ilmestyessä."
  noindex={true}
>
  <div class="page max">
    <section class="thanks glass">
      <p class="eyebrow">Onnistui</p>
      <h1>Kiitos <span>tilauksesta</span>!</h1>
      <p class="muted">
        Saat sähköpostiisi lyhyen muistutuksen aina kun uusi jakso ilmestyy.
        Voit peruuttaa tilauksen milloin tahansa viestin lopussa olevasta linkistä.
      </p>
      <div class="actions">
        <a class="btn" href="/jaksot">Selaa jaksoja</a>
        <a class="btn alt" href="/">Etusivulle</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 7rem;
  }

  .thanks {
    padding: clamp(1.4rem, 4vw, 2.6rem);
    max-width: 680px;
  }

  .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: 0.7rem;
    font-weight: 700;
    margin: 0 0 0.8rem;
  }

  h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    text-transform: uppercase;
    font-style: italic;
  }

  h1 span {
    color: var(--accent);
  }

  .actions {
    margin-top: 1.2rem;
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
</style>
