---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEpisodesFromRSS } from '../../lib/rss';

const episodes = await getEpisodesFromRSS();
const demo = episodes[0];
const embedSrc = demo ? `/jaksot/${demo.slug}/embed` : null;
---

<BaseLayout
  title="Upotus-demonstraatio | RAAKAA"
  description="Esikatselu siitä, miltä jakson upotettu soitin näyttää kolmannen osapuolen sivulla."
  noindex={true}
>
  <div class="page max">
    <h1>Upotetun soittimen demo</h1>
    <p class="lead muted">
      Alla on sama <code>&lt;iframe&gt;</code>-upotus kuin jakson sivulla. Kehys on 180&nbsp;px korkuinen, kuten
      suositellussa upotuskoodissa.
    </p>

    {
      embedSrc && demo ? (
        <>
          <p class="meta">
            Jakso: <a href={`/jaksot/${demo.slug}`}>{demo.title}</a>
            <span class="sep">·</span>
            <code class="src">{embedSrc}</code>
          </p>

          <div class="third-party" aria-label="Esimerkki upotuksesta valkoisella taustalla">
            <p class="third-party-label">Esimerkki: toisen sivuston harmaa laatikko</p>
            <iframe
              src={embedSrc}
              width="100%"
              height="180"
              style="border:0;"
              title={demo.title}
              allow="autoplay"
            />
          </div>

          <div class="third-party third-party--dark" aria-label="Esimerkki upotuksesta tummalla taustalla">
            <p class="third-party-label">Esimerkki: tumma tausta</p>
            <iframe
              src={embedSrc}
              width="100%"
              height="180"
              style="border:0;"
              title={demo.title}
              allow="autoplay"
            />
          </div>
        </>
      ) : (
        <p class="muted">RSSistä ei löytynyt jaksoja — upotusta ei voi näyttää.</p>
      )
    }
  </div>
</BaseLayout>

<style>
  .page {
    padding: 7rem 0 4rem;
  }

  h1 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin: 0 0 0.75rem;
  }

  .lead {
    margin: 0 0 1.5rem;
    max-width: 55ch;
    line-height: 1.65;
  }

  .lead code {
    font-size: 0.88em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.08);
  }

  .meta {
    margin: 0 0 1.25rem;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.5;
    word-break: break-word;
  }

  .meta a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sep {
    margin: 0 0.35em;
    opacity: 0.5;
  }

  .src {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .third-party {
    padding: 1.25rem 1.25rem 1.5rem;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    max-width: 520px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: #e8e8e8;
    color: #222;
  }

  .third-party--dark {
    background: #1a1a1a;
    border-color: var(--border);
    color: var(--text);
  }

  .third-party-label {
    margin: 0 0 0.75rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  .third-party--dark .third-party-label {
    color: var(--muted);
  }

  iframe {
    display: block;
    border-radius: 8px;
    background: #0c0c0c;
  }
</style>
