---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kiitos viestistä | RAAKAA Podcast" description="Kiitos yhteydenotosta.">
  <section class="thanks glass">
    <h1>Kiitos viestistäsi!</h1>
    <p class="muted">Viestisi on vastaanotettu. Palaamme asiaan mahdollisimman pian.</p>
    <a class="btn" href="/">Takaisin etusivulle</a>
  </section>
</BaseLayout>

<style>
  .thanks {
    margin: 2rem 0 3rem;
    padding: 1.4rem;
    max-width: 700px;
  }

  h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
  }
</style>
