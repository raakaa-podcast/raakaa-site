---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEpisodesFromRSS } from '../../lib/rss';
import { getAllGuests, getEpisodesForGuest } from '../../lib/episodeMeta';

const guests = getAllGuests();
const episodes = await getEpisodesFromRSS();

const guestEntries = guests.map((g) => ({
  guest: g,
  episodes: getEpisodesForGuest(g.slug, episodes),
}));
---

<BaseLayout
  title="Vieraat | RAAKAA Podcast"
  description="Tutustu RAAKAA Podcastin vieraisiin. Lyhyet esittelyt, linkit heidän työhönsä ja kaikki jaksot, joissa he ovat olleet mukana."
>
  <div class="page max">
    <header class="page-head">
      <h1>RAAKAA Podcastin <span>vieraat</span></h1>
      <p class="muted">
        Listalla kaikki RAAKAA Podcastin vieraat. Klikkaa nimeä avataksesi vieraan oman sivun, jolta löydät esittelyn,
        linkit ja kaikki jaksot, joissa vieras on ollut mukana.
      </p>
    </header>

    {guestEntries.length > 0 ? (
      <div class="guest-grid">
        {guestEntries.map(({ guest, episodes: epList }) => (
          <article class="guest-card glass">
            <a class="guest-link" href={`/vieraat/${guest.slug}`}>
              {guest.image && (
                <img
                  class="guest-photo"
                  src={guest.image}
                  alt={guest.name}
                  loading="lazy"
                  decoding="async"
                  width="600"
                  height="600"
                />
              )}
              {!guest.image && <div class="guest-photo placeholder" aria-hidden="true">{guest.name.charAt(0)}</div>}
              <div>
                <h2>{guest.name}</h2>
                {guest.role && <p class="role">{guest.role}</p>}
                <p class="bio">{guest.bio.slice(0, 160)}{guest.bio.length > 160 ? '…' : ''}</p>
                <p class="ep-count muted">{epList.length} jakso{epList.length === 1 ? '' : 'a'}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="muted empty">
        Vieraita ei ole vielä lisätty. Lisää uusia vieraita tiedostoon{' '}
        <code>src/data/guests.json</code> ja yhdistä jaksoihin tiedostossa <code>src/data/episode-meta.json</code>.
      </p>
    )}
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 7rem;
  }

  .page-head {
    margin-bottom: 2rem;
    max-width: 720px;
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    text-transform: uppercase;
    font-style: italic;
    margin: 0 0 0.6rem;
  }

  h1 span {
    color: var(--accent);
  }

  .guest-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 360px));
    justify-content: start;
  }

  .guest-card {
    padding: 0;
    overflow: hidden;
    transition: border-color 180ms ease;
  }

  .guest-card:hover {
    border-color: rgba(255, 212, 0, 0.4);
  }

  .guest-link {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1rem;
    padding: 1rem;
    color: inherit;
  }

  .guest-photo {
    width: 110px;
    height: 110px;
    border-radius: 12px;
    object-fit: cover;
    filter: grayscale(1);
    transition: filter 280ms ease, transform 320ms ease;
  }

  .guest-photo.placeholder {
    background: rgba(255, 212, 0, 0.12);
    color: var(--accent);
    font-weight: 800;
    font-size: 2rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--border);
  }

  .guest-link:hover .guest-photo:not(.placeholder) {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .role {
    margin: 0.2rem 0 0.6rem;
    color: var(--accent);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  .bio {
    margin: 0 0 0.55rem;
    color: var(--muted);
    line-height: 1.5;
    font-size: 0.92rem;
  }

  .ep-count {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .empty {
    padding: 1.4rem;
    border-radius: var(--radius);
    border: 1px dashed var(--border);
  }

  .empty code {
    font-size: 0.88em;
    padding: 0.12rem 0.35rem;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--border);
  }
</style>
