---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EpisodeButtons from '../../../components/EpisodeButtons.astro';
import EpisodeCard from '../../../components/EpisodeCard.astro';
import EpisodeShareRow from '../../../components/EpisodeShareRow.astro';
import YoutubeEmbed from '../../../components/YoutubeEmbed.astro';
import { formatFinnishDate, getEpisodesFromRSS, type Episode } from '../../../lib/rss';
import { getTranscriptHtmlForEpisode } from '../../../lib/transcripts';
import { getPdfTranscriptForEpisode } from '../../../lib/litteroinnit';
import {
  formatDuration,
  getEpisodeMeta,
  getGuestBySlug,
  getRelatedEpisodes,
  resolveGuestNames,
} from '../../../lib/episodeMeta';
import { getPodcastEpisodeSchema } from '../../../lib/structuredData';

export async function getStaticPaths() {
  const episodes = await getEpisodesFromRSS();
  return episodes.map((episode) => ({
    params: { slug: episode.slug },
    props: { episode, allEpisodes: episodes },
  }));
}

type Props = { episode: Episode; allEpisodes: Episode[] };
const { episode, allEpisodes } = Astro.props;

const transcriptHtml = await getTranscriptHtmlForEpisode(episode);
const pdfTranscript = await getPdfTranscriptForEpisode(episode);
const cleanDescription = episode.description.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
const meta = getEpisodeMeta(episode);
const duration = formatDuration(episode.duration);
const guests = resolveGuestNames(meta.guests ?? []);
const topics = meta.topics ?? [];

const heroImage = episode.imageUrl;

const episodeSchema = getPodcastEpisodeSchema(episode, meta);
const ogImagePath = `/og/jaksot/${episode.slug}.png`;

const guestProfiles = (meta.guests ?? [])
  .map((slug) => getGuestBySlug(slug))
  .filter((g): g is NonNullable<ReturnType<typeof getGuestBySlug>> => g !== null);

const relatedEpisodes = getRelatedEpisodes(episode, allEpisodes, 3);

const canonicalUrl = new URL(`/jaksot/${episode.slug}`, Astro.site).href;

const stripHtml = (value: string) => value.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const guestExcerpt = (bio: string, max = 180) => {
  const text = stripHtml(bio);
  return text.length > max ? `${text.slice(0, max).trimEnd()}…` : text;
};
---

<BaseLayout
  title={`${episode.title} | RAAKAA Podcast`}
  description={cleanDescription.slice(0, 160)}
  ogImage={ogImagePath}
  ogType="article"
  structuredData={episodeSchema}
>
  <div class="page max">
    <nav class="breadcrumb" aria-label="Murupolku">
      <a href="/jaksot">← Kaikki jaksot</a>
    </nav>

    <article class="episode-detail glass">
      <div class="meta-row">
        <span class="date">{formatFinnishDate(episode.publishedAt)}</span>
        {duration && <span class="duration" aria-label={`Kesto ${duration}`}>{duration}</span>}
      </div>

      <h1>{episode.title}</h1>

      {guests.length > 0 && (
        <p class="guests">
          <span class="label">Vieras{guests.length === 1 ? '' : 'sat'}:</span>
          {guests.map((g, i) => (
            <span>
              <a href={`/vieraat/${g.slug}`}>{g.name}</a>{i < guests.length - 1 ? ', ' : ''}
            </span>
          ))}
        </p>
      )}

      {topics.length > 0 && (
        <ul class="topics" aria-label="Aiheet">
          {topics.map((t) => <li class="topic">#{t}</li>)}
        </ul>
      )}

      {heroImage && (
        <div class="cover">
          <img
            src={heroImage}
            alt={episode.title}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            width="800"
            height="800"
          />
        </div>
      )}

      <div class="description" set:html={episode.description}></div>

      <EpisodeShareRow title={episode.title} url={canonicalUrl} slug={episode.slug} />

      <div class="actions">
        <EpisodeButtons
          slug={episode.slug}
          title={episode.title}
          audioUrl={episode.audioUrl}
          size="default"
          showOpenLink={false}
          youtubeUrl={meta.youtubeUrl}
        />
      </div>

      <YoutubeEmbed youtubeUrl={meta.youtubeUrl} />
    </article>

    {guestProfiles.length > 0 && (
      <section class="guest-cards" aria-labelledby="guest-cards-title">
        <h2 id="guest-cards-title" class="section-title">Tässä jaksossa</h2>
        <div class="guest-card-grid">
          {guestProfiles.map((g) => (
            <a
              class="guest-card glass"
              href={`/vieraat/${g.slug}`}
              aria-label={`Lue lisää vieraasta ${g.name}`}
            >
              {g.image ? (
                <img
                  class="guest-photo"
                  src={g.image}
                  alt={g.name}
                  loading="lazy"
                  decoding="async"
                  width="320"
                  height="320"
                />
              ) : (
                <div class="guest-photo placeholder" aria-hidden="true">{g.name.charAt(0)}</div>
              )}
              <div class="guest-body">
                <p class="eyebrow">Vieras</p>
                <h3 class="guest-name">{g.name}</h3>
                {g.role && <p class="guest-role">{g.role}</p>}
                <p class="guest-bio">{guestExcerpt(g.bio)}</p>
                <span class="guest-cta" aria-hidden="true">Vieraan profiili →</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {(transcriptHtml || pdfTranscript) && (
      <section class="transcript glass" aria-labelledby="transcript-title">
        <h2 id="transcript-title" class="section-title">Jakson litterointi</h2>
        {transcriptHtml ? (
          <div class="transcript-md transcript-plain" set:html={transcriptHtml}></div>
        ) : pdfTranscript ? (
          <div class="transcript-pdf">
            <p class="transcript-pdf-intro">
              <a
                class="transcript-pdf-link"
                href={pdfTranscript.data.pdfUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Avaa tai lataa litterointi PDF-tiedostona
              </a>
            </p>
            <iframe
              class="transcript-pdf-frame"
              src={pdfTranscript.data.pdfUrl}
              title={pdfTranscript.data.title || 'Jakson litterointi PDF-muodossa'}
            />
          </div>
        ) : null}
      </section>
    )}

    {relatedEpisodes.length > 0 && (
      <section class="related" aria-labelledby="related-title">
        <h2 id="related-title" class="section-title">Lisää jaksoja</h2>
        <div class="related-grid">
          {relatedEpisodes.map((ep) => (
            <EpisodeCard episode={ep} headingLevel="h3" />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 7rem;
  }

  .breadcrumb {
    margin-bottom: 1rem;
  }

  .breadcrumb a {
    color: var(--muted);
    font-size: 0.85rem;
    transition: color 150ms ease;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .episode-detail {
    padding: clamp(1.2rem, 3vw, 2.4rem);
    margin-bottom: 1.6rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    font-weight: 700;
    margin: 0;
  }

  .date {
    color: var(--accent);
  }

  .duration {
    color: var(--muted);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
  }

  h1 {
    margin: 0.6rem 0 0.8rem;
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    line-height: 1.1;
  }

  .guests {
    margin: 0 0 0.6rem;
    color: var(--muted);
    font-size: 1rem;
  }

  .guests .label {
    color: var(--text);
    font-weight: 600;
    margin-right: 0.4rem;
  }

  .guests a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .topics {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .topic {
    font-size: 0.72rem;
    color: var(--muted);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
  }

  .cover {
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid var(--border);
    margin: 0.4rem 0 1.4rem;
    width: min(100%, 520px);
  }

  .cover img {
    width: 100%;
    display: block;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    filter: grayscale(1);
    transition: filter 320ms ease, transform 380ms ease;
  }

  .cover:hover img,
  .cover:focus-within img {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  .actions {
    margin-bottom: 1.4rem;
  }

  .description {
    color: var(--muted);
    line-height: 1.7;
  }

  .description :global(img),
  .description :global(video),
  .description :global(iframe) {
    max-width: 100%;
    height: auto;
    border-radius: 10px;
  }

  .description :global(pre) {
    overflow-x: auto;
  }

  .transcript {
    margin-bottom: 1.6rem;
    padding: clamp(1.2rem, 3vw, 2rem);
  }

  .transcript-plain {
    color: var(--muted);
    line-height: 1.7;
  }

  .transcript-md :global(p) {
    margin: 0 0 0.85rem;
  }

  .transcript-md :global(p:last-child) {
    margin-bottom: 0;
  }

  .transcript-md :global(ul),
  .transcript-md :global(ol) {
    margin: 0 0 0.85rem 1.25rem;
    padding: 0;
  }

  .transcript-md :global(li) {
    margin-bottom: 0.35rem;
  }

  .transcript-md :global(strong) {
    color: var(--text);
    font-weight: 700;
  }

  .transcript-md :global(code) {
    font-size: 0.9em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.06);
  }

  .transcript-md :global(pre) {
    overflow-x: auto;
    margin: 0 0 0.85rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid var(--border);
  }

  .transcript-md :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .transcript-pdf-intro {
    margin: 0 0 1rem;
  }

  .transcript-pdf-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .transcript-pdf-frame {
    width: 100%;
    min-height: min(70vh, 720px);
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.2);
  }

  iframe {
    border: 0;
    border-radius: 10px;
    background: #0e0e0e;
  }

  .guest-cards {
    margin-bottom: 1.6rem;
  }

  .guest-cards .section-title {
    margin: 0 0 1rem;
    font-size: clamp(1.4rem, 2.6vw, 1.8rem);
  }

  .guest-card-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 360px), 1fr));
  }

  .guest-card {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.1rem;
    padding: 1rem;
    color: inherit;
    transition: border-color 180ms ease, transform 220ms ease;
  }

  .guest-card:hover,
  .guest-card:focus-visible {
    border-color: rgba(255, 212, 0, 0.45);
    transform: translateY(-2px);
  }

  .guest-photo {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .guest-photo.placeholder {
    background: rgba(255, 212, 0, 0.12);
    color: var(--accent);
    font-weight: 800;
    font-size: 3rem;
    display: grid;
    place-items: center;
  }

  .guest-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .guest-body .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.66rem;
    font-weight: 700;
    margin: 0 0 0.35rem;
  }

  .guest-name {
    margin: 0 0 0.3rem;
    font-size: 1.2rem;
    line-height: 1.2;
  }

  .guest-role {
    margin: 0 0 0.5rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    font-weight: 700;
  }

  .guest-bio {
    margin: 0 0 0.8rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .guest-cta {
    margin-top: auto;
    color: var(--accent);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }

  .related {
    margin-bottom: 1.6rem;
  }

  .related .section-title {
    margin: 0 0 1rem;
    font-size: clamp(1.4rem, 2.6vw, 1.8rem);
  }

  .related-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  @media (max-width: 540px) {
    .guest-card {
      grid-template-columns: 1fr;
    }

    .guest-photo {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
    }
  }
</style>
