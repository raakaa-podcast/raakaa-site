---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import EpisodeCard from '../../../../components/EpisodeCard.astro';
import { getEpisodesFromRSS, type Episode } from '../../../../lib/rss';
import { collectTopicIndex, episodesForTagSlug } from '../../../../lib/topics';

export async function getStaticPaths() {
  const episodes = await getEpisodesFromRSS();
  const index = collectTopicIndex(episodes);
  return index.map(({ slug, label }) => ({
    params: { tag: slug },
    props: { label, episodes: episodesForTagSlug(episodes, slug) as Episode[] },
  }));
}

type Props = { label: string; episodes: Episode[] };
const { label, episodes: tagged } = Astro.props;
const tagParam = Astro.params.tag ?? '';

const description = `RAAKAA Podcastin jaksot aiheesta «${label}». Selaa kaikki merkityt jaksot.`;
const title = `${label} | Aihe | RAAKAA Podcast`;

const itemListElements = tagged.map((ep, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  url: new URL(`/jaksot/${ep.slug}`, Astro.site).href,
  name: ep.title,
}));

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${label} – RAAKAA Podcast`,
  description,
  url: new URL(`/jaksot/tag/${tagParam}`, Astro.site).href,
  isPartOf: { '@type': 'WebSite', name: 'RAAKAA Podcast', url: Astro.site?.href ?? '' },
  ...(itemListElements.length > 0
    ? {
        mainEntity: {
          '@type': 'ItemList',
          itemListElement: itemListElements,
        },
      }
    : {}),
};
---

<BaseLayout title={title} description={description.slice(0, 160)} structuredData={collectionSchema}>
  <div class="page max">
    <nav class="breadcrumb" aria-label="Murupolku">
      <a href="/jaksot">← Kaikki jaksot</a>
    </nav>

    <header class="page-head">
      <p class="eyebrow">Aihe</p>
      <h1>#{label}</h1>
      <p class="lede muted">
        {tagged.length > 0
          ? `${tagged.length} ${tagged.length === 1 ? 'jakso' : 'jaksoa'} tällä aiheella.`
          : 'Tähän aiheeseen ei löytynyt jaksoja.'}
      </p>
    </header>

    {tagged.length > 0 ? (
      <div class="episode-grid">
        {tagged.map((episode) => (
          <EpisodeCard episode={episode} headingLevel="h2" />
        ))}
      </div>
    ) : (
      <p class="muted empty">Tämä aihesivu on tyhjä. Palaa <a href="/jaksot">jaksoihin</a>.</p>
    )}
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 7rem;
  }

  .breadcrumb {
    margin-bottom: 1rem;
  }

  .breadcrumb a {
    color: var(--muted);
    font-size: 0.85rem;
    transition: color 150ms ease;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .page-head {
    margin-bottom: 1.75rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    color: var(--accent);
  }

  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.75rem, 4vw, 2.6rem);
    line-height: 1.15;
  }

  .lede {
    margin: 0;
    font-size: 1rem;
    max-width: 42rem;
  }

  .episode-grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
    margin-bottom: 2rem;
  }

  .empty a {
    color: var(--accent);
  }
</style>
