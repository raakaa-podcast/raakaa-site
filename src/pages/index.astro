---
import BaseLayout from '../layouts/BaseLayout.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import ListenMenu from '../components/ListenMenu.astro';
import SocialIcons from '../components/SocialIcons.astro';
import {
  LISTEN_APPLE_URL,
  LISTEN_RSS_COM_URL,
  LISTEN_SPOTIFY_URL,
  LISTEN_YOUTUBE_URL,
} from '../data/listen-platforms';
import { getEpisodesFromRSS } from '../lib/rss';

const episodes = await getEpisodesFromRSS();
const latestEpisodes = episodes.slice(0, 3);

const faqItems = [
  {
    question: 'Mistä kuuntelen RAAKAA Podcastin uusimmat jaksot?',
    answer:
      'RAAKAA Podcast julkaistaan audiomuodossa 22 eri alustalle. Kaikki jaksot ovat saatavilla videoversioina YouTubessa ja Spotifyssa. Audioversio jaetaan alustoille: Apple Podcasts, Amazon Music, Podcast Index, Listen Notes, RSS.com Community, Castamatic, Castbox, Castro, Curiocaster, Fountain, Overcast, Pocket Casts, Podcast Addict, Podcast Guru, PodLP, Podverse, TrueFans, Deezer, iHeartRadio, Pandora ja Tune In.',
  },
  {
    question: 'Kuinka usein uusia jaksoja julkaistaan?',
    answer:
      'Julkaisutahti voi aluksi vaihdella, mutta tavoitteena on julkaista uusi jakso joka torstai. Vierasehdotuksia voi lähettää sivuston yhteydenottolomakkeella.',
  },
  {
    question: 'Mistä löydän jaksojen litteroinnit?',
    answer:
      'Litteroinnit löytyvät tekstimuodossa suoraan yksittäisen jakson sivulta, kun litterointi on lisätty jaksolle.',
  },
  {
    question: 'Voinko ehdottaa vierasta tai aihetta?',
    answer:
      'Kyllä – etusivun yhteydenottolomakkeen kautta voit ehdottaa vierasta, aihetta tai antaa muuta palautetta. Luen kaikki viestit henkilökohtaisesti.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RAAKAA Podcast',
  url: 'https://www.raakaa.fi',
  logo: 'https://www.raakaa.fi/og-image.jpg',
  sameAs: [
    LISTEN_SPOTIFY_URL,
    LISTEN_APPLE_URL,
    LISTEN_YOUTUBE_URL,
    'https://www.instagram.com/raakaapodcast',
    'https://x.com/raakaapodcast',
    LISTEN_RSS_COM_URL,
  ],
};
---

<BaseLayout
  title="RAAKAA Podcast – suomalainen keskustelupodcast | Markus Suominen"
  description="RAAKAA on rehellinen ja kiehtova suomalainen keskustelupodcast. Pitkät keskustelut yhteiskunnasta, ihmismielestä ja ajankohtaisista aiheista. Kuuntele Spotifyssa, Apple Podcastsissa, YouTubessa ja muilla 22 alustalla."
  structuredData={[faqSchema, orgSchema]}
>
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg" aria-hidden="true">
      <img
        src="https://images.unsplash.com/photo-1478737270239-2f02b77fc618?q=70&w=1600&auto=format&fit=crop"
        alt=""
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1600"
        height="900"
      />
      <div class="hero-gradient"></div>
    </div>
    <div class="hero-content">
      <p class="eyebrow">Markus Suominen esittää</p>
      <h1 id="hero-title">REHELLISTÄ.<br />SUORAA. <span>RAAKAA.</span></h1>
      <p class="hero-lead">
        Suomalainen keskustelupodcast, jossa annetaan vieraille aikaa, tilaa ja mahdollisuus kertoa oma näkökulma ilman turhaa silottelua.
      </p>
      <ListenMenu variant="hero" />
    </div>
  </section>

  {latestEpisodes.length > 0 && (
    <section id="jaksot" class="episodes max" aria-labelledby="jaksot-title">
      <div class="section-head">
        {episodes.length === 1 ? (
          <h2 id="jaksot-title">Uusin <span>jakso</span></h2>
        ) : (
          <h2 id="jaksot-title">Uusimmat <span>jaksot</span></h2>
        )}
        {episodes.length > 3 && <a class="btn alt small" href="/jaksot">Selaa kaikki</a>}
      </div>
      <div class={`episode-grid count-${latestEpisodes.length}`}>
        {latestEpisodes.map((episode) => (
          <EpisodeCard episode={episode} />
        ))}
      </div>
    </section>
  )}

  <section class="seo max" aria-labelledby="about-title">
    <div class="seo-grid glass">
      <div>
        <h2 id="about-title">Mikä on <span>RAAKAA Podcast</span>?</h2>
        <p>
          RAAKAA on suomalainen keskustelupodcast, jossa käsitellään yhteiskuntaa, ihmismieltä, ilmiöitä ja
          ajankohtaisia aiheita suoraan ja ilman turhaa silottelua. Pitkät, syvälle menevät keskustelut tarjoavat
          tilaa ajatuksille, jotka jäävät uutispätkien ja sosiaalisen median klippien jalkoihin.
        </p>
        <p>
          Jokainen podcast-jakso julkaistaan RSS.comin kautta, ja uudet jaksot nousevat tälle sivulle automaattisesti.
          Voit kuunnella RAAKAA Podcastia Spotifyssa, Apple Podcastsissa, YouTubessa ja kaikilla yleisillä
          podcast-alustoilla – yhteensä 22 eri palvelussa.
        </p>
      </div>
      <ul class="seo-list">
        <li>
          <strong>Kieli:</strong>
          <span>Suomi</span>
        </li>
        <li>
          <strong>Formaatti:</strong>
          <span>Pitkät haastattelut ja keskustelut</span>
        </li>
        <li>
          <strong>Julkaisutahti:</strong>
          <span>Tavoite: joka torstai</span>
        </li>
        <li>
          <strong>Saavutettavuus:</strong>
          <span>Tekstilitteroinnit suoraan jaksosivuilla</span>
        </li>
        <li>
          <strong>Juontaja:</strong>
          <span>Markus Suominen</span>
        </li>
      </ul>
    </div>
  </section>

  <section id="markus" class="markus" aria-labelledby="markus-title">
    <div class="max markus-grid">
      <a class="img-wrap" href="/markus" aria-label="Lue koko tarinani" data-reveal>
        <img
          src="/images/markus-suominen.jpg"
          alt="Markus Suominen, RAAKAA Podcastin juontaja"
          loading="lazy"
          decoding="async"
          width="1536"
          height="2048"
        />
      </a>
      <div>
        <p class="kicker">Juontaja</p>
        <h3 id="markus-title">Markus <span>Suominen</span></h3>
        <p>
          Olen elämän koulima joka paikan höylä, joka ymmärtää niin koneita, koodia kuin ihmismieltä. Maailmaa
          nähnyt seikkailija, joka osaa ottaa tilanteen haltuun paikasta ja seurasta riippumatta.
        </p>
        <p>
          Olen kulkenut polun, joka on vienyt minut yli 40 maahan, pinnan alle PADI Rescue Diverina, metsään
          enduropyörällä ja korkeuksiin laskuvarjolla. Tämä elämänkokemus heijastuu kaikkeen tekemiseeni.
        </p>
        <p>
          <a class="btn alt" href="/markus">Lue koko tarinani</a>
        </p>
      </div>
    </div>
  </section>

  <section id="seuraa" class="follow max" aria-labelledby="follow-title">
    <h2 id="follow-title">Seuraa <span>kaikilla</span> alustoilla</h2>
    <p class="muted">
      RAAKAA Podcast julkaistaan 22 eri palveluun. Tilaa suosikkialustallasi tai liity yhteisöön sosiaalisessa mediassa.
    </p>
    <ul class="platform-grid">
      <li><a class="platform glass" href={LISTEN_SPOTIFY_URL} target="_blank" rel="noreferrer"><SocialIcons name="spotify" size={22} /><span>Spotify</span></a></li>
      <li><a class="platform glass" href={LISTEN_APPLE_URL} target="_blank" rel="noreferrer"><SocialIcons name="apple" size={22} /><span>Apple Podcasts</span></a></li>
      <li><a class="platform glass" href={LISTEN_YOUTUBE_URL} target="_blank" rel="noreferrer"><SocialIcons name="youtube" size={22} /><span>YouTube</span></a></li>
      <li><a class="platform glass" href="https://www.instagram.com/raakaapodcast" target="_blank" rel="noreferrer"><SocialIcons name="instagram" size={22} /><span>Instagram</span></a></li>
      <li><a class="platform glass" href="https://x.com/raakaapodcast" target="_blank" rel="noreferrer"><SocialIcons name="x" size={22} /><span>X</span></a></li>
      <li><a class="platform glass" href={LISTEN_RSS_COM_URL} target="_blank" rel="noreferrer"><SocialIcons name="rss" size={22} /><span>RSS.com</span></a></li>
    </ul>
  </section>

  <section id="tilaa" class="newsletter max" aria-labelledby="newsletter-title">
    <div class="newsletter-card glass">
      <div class="newsletter-text">
        <p class="eyebrow">Uutiskirje</p>
        <h2 id="newsletter-title">Tilaa <span>jaksomuistutus</span> sähköpostiin</h2>
        <p class="muted">
          Saat lyhyen viestin aina kun uusi jakso ilmestyy – mukaan otsikko, vieraat ja linkki jaksoon.
          Ei spämmiä, ei mainoksia, peruuta milloin haluat.
        </p>
      </div>
      <form
        id="tilaus-form"
        class="newsletter-form"
        name="tilaus"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/kiitos-tilaus"
      >
        <input type="hidden" name="form-name" value="tilaus" />
        <p class="hp-field" aria-hidden="true">
          <label>Älä täytä tätä kenttää: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>
        <label class="visually-hidden" for="tilaus-email">Sähköpostiosoite (pakollinen)</label>
        <input
          id="tilaus-email"
          type="email"
          name="sahkoposti"
          required
          autocomplete="email"
          placeholder="oma@osoite.fi"
          aria-required="true"
        />
        <label class="consent">
          <input type="checkbox" name="suostumus" value="kylla" required aria-required="true" />
          <span>
            Hyväksyn, että sähköpostiosoitettani käytetään ainoastaan jaksomuistutuksiin. Lue{' '}
            <a class="form-inline-link" href="/tietosuoja">tietosuojaseloste</a>.{' '}
            <span class="req" aria-hidden="true">*</span>
          </span>
        </label>
        <button class="btn" type="submit">Tilaa</button>
      </form>
    </div>
  </section>

  <section id="yhteys" class="contact max" aria-labelledby="contact-title">
    <h2 id="contact-title">Ota <span>yhteyttä</span></h2>
    <p class="muted">
      Voit ehdottaa vierasta, aihetta tai antaa muuta palautetta.
    </p>
    <form
      id="yhteydenotto-form"
      class="glass contact-form"
      name="yhteydenotto"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/kiitos"
    >
      <input type="hidden" name="form-name" value="yhteydenotto" />
      <p class="hp-field" aria-hidden="true">
        <label>Älä täytä tätä kenttää: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>
      <label>
        <span>Nimi <span class="req" aria-hidden="true">*</span></span>
        <input type="text" name="nimi" required autocomplete="name" />
      </label>
      <label>
        <span>Sähköposti <span class="req" aria-hidden="true">*</span></span>
        <input type="email" name="sahkoposti" required autocomplete="email" />
      </label>
      <label class="full">
        <span>Aihe</span>
        <select name="aihe">
          <option value="vierasvinkki">Vierasehdotus</option>
          <option value="aihe-ehdotus">Aihe-ehdotus</option>
          <option value="palaute">Palaute</option>
          <option value="muu">Muu</option>
        </select>
      </label>
      <label class="full">
        <span>Viesti <span class="req" aria-hidden="true">*</span></span>
        <textarea name="viesti" rows="5" required></textarea>
      </label>
      <p class="form-note muted">
        <span aria-hidden="true">*</span> Pakollinen kenttä. Lue{' '}
        <a class="form-inline-link" href="/tietosuoja">tietosuojaseloste</a>.
      </p>
      <button class="btn full-btn" type="submit">Lähetä viesti</button>
    </form>
  </section>

  <section class="faq max" aria-labelledby="faq-title">
    <div class="faq-header">
      <h2 id="faq-title">Usein kysytyt <span>kysymykset</span></h2>
      <a class="btn faq-cta" href="#yhteys">Ehdota vierasta</a>
    </div>
    <p class="faq-intro muted">
      Alla yleisimmät kysymykset RAAKAA Podcastista. Voit ehdottaa vierasta tai lähettää muun viestin yhteydenottolomakkeella.
    </p>
    <div class="faq-list">
      {faqItems.map((item) => (
        <article class="glass faq-item">
          <h3>{item.question}</h3>
          <p class="faq-answer">{item.answer}</p>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    (function () {
      var targets = document.querySelectorAll('[data-reveal]');
      if (!targets.length) return;

      var reduceMotion =
        window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduceMotion || !('IntersectionObserver' in window)) {
        targets.forEach(function (el) {
          el.classList.add('is-revealed');
        });
        return;
      }

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.25, rootMargin: '0px 0px -10% 0px' },
      );

      targets.forEach(function (el) {
        observer.observe(el);
      });
    })();
  </script>
</BaseLayout>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: visible;
    margin-top: -1px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.22;
    transform: scale(1.05);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(250, 204, 21, 0.05) 0%, rgba(10, 10, 10, 1) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1rem;
    max-width: 820px;
  }

  .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.35em;
    font-size: 0.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.6rem, 10vw, 7rem);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  h1 span,
  h2 span,
  .markus h3 span {
    color: var(--accent);
  }

  .hero-lead {
    color: var(--muted);
    margin: 1.5rem auto 0;
    max-width: 56ch;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .follow {
    padding: 5rem 0 3rem;
  }

  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .episodes h2,
  .follow h2,
  .contact h2,
  .faq h2 {
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-style: italic;
    text-transform: uppercase;
    margin: 0;
  }

  .episode-grid {
    display: grid;
    gap: 1rem;
  }

  .episode-grid.count-1 {
    grid-template-columns: minmax(0, 480px);
    justify-content: center;
  }

  .episode-grid.count-2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    max-width: 880px;
    margin-inline: auto;
  }

  .episode-grid.count-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .seo {
    padding: 2rem 0;
  }

  .seo-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2rem;
    padding: clamp(1.2rem, 3vw, 2.2rem);
  }

  .seo h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin: 0 0 0.8rem;
  }

  .seo p {
    color: var(--muted);
    margin: 0.65rem 0;
    line-height: 1.7;
  }

  .seo-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .seo-list li {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.95rem;
  }

  .seo-list strong {
    color: var(--text);
  }

  .seo-list span {
    color: var(--muted);
    text-align: right;
  }

  .markus {
    padding: 5rem 0;
    background: #0f0f0f;
  }

  .markus-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: 1fr 1.2fr;
    align-items: center;
  }

  .img-wrap {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .img-wrap img {
    width: 100%;
    display: block;
    filter: grayscale(1);
    transform: scale(1.02);
    opacity: 0.85;
    transition:
      filter 900ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 900ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 600ms ease;
  }

  .img-wrap[data-reveal].is-revealed img {
    filter: grayscale(0);
    transform: scale(1);
    opacity: 1;
  }

  .img-wrap:hover img,
  .img-wrap:focus-within img {
    filter: grayscale(0);
    transform: scale(1.03);
  }

  @media (prefers-reduced-motion: reduce) {
    .img-wrap img {
      filter: grayscale(0);
      transform: none;
      opacity: 1;
      transition: none;
    }
  }

  .markus .kicker {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.72rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
  }

  .markus h3 {
    margin: 0 0 1rem;
    font-size: clamp(2rem, 5vw, 3.2rem);
    text-transform: uppercase;
    font-style: italic;
  }

  .markus p {
    color: var(--muted);
    line-height: 1.7;
  }

  .platform-grid {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .platform {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.95rem 1.1rem;
    color: var(--text);
    transition: border-color 150ms ease, transform 150ms ease, color 150ms ease;
  }

  .platform:hover {
    border-color: rgba(255, 212, 0, 0.4);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .newsletter {
    padding: 3rem 0 1rem;
  }

  .newsletter-card {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 2rem;
    padding: clamp(1.4rem, 3vw, 2.4rem);
    align-items: center;
  }

  .newsletter-text .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    font-size: 0.7rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
  }

  .newsletter-text h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    margin: 0 0 0.7rem;
    text-transform: uppercase;
    font-style: italic;
    line-height: 1.1;
  }

  .newsletter-text h2 span {
    color: var(--accent);
  }

  .newsletter-text p {
    margin: 0;
    line-height: 1.6;
    max-width: 48ch;
  }

  .newsletter-form {
    display: grid;
    gap: 0.7rem;
  }

  .newsletter-form input[type='email'] {
    border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    padding: 0.85rem 1.1rem;
    font: inherit;
  }

  .newsletter-form input[type='email']:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .consent {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .consent input {
    margin-top: 0.18rem;
    accent-color: var(--accent);
  }

  .form-inline-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .form-inline-link:hover {
    color: var(--text);
    text-decoration-color: var(--accent);
  }

  .form-inline-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact {
    padding: 4rem 0 3rem;
  }

  .contact-form {
    margin-top: 1.4rem;
    padding: 1.4rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .hp-field {
    position: absolute;
    left: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  label {
    display: flex;
