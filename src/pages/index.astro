---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEpisodesFromRSS } from '../lib/rss';
import { getCollection } from 'astro:content';
import { formatFinnishDate } from '../lib/rss';

const episodes = await getEpisodesFromRSS();
const latestEpisodes = episodes.slice(0, 3);
const pdfTranscripts = (await getCollection('pdfTranscripts')).slice(0, 4);

const stripHtml = (value: string) => value.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const episodeSlots = Array.from({ length: 3 }, (_, index) => latestEpisodes[index] ?? null);

const faqItems = [
  {
    question: 'Mistä kuuntelen RAAKAA Podcastin uusimmat jaksot?',
    answer:
      'RAAKAA Podcast julkaistaan audiomuodossa 22 eri alustalle. Kaikki jaksot ovat saatavilla videoversioina YouTubessa ja Spotifyssa. Audioversio jaetaan alustoille: Apple Podcasts, Amazon Music, Podcast Index, Listen Notes, RSS.com Community, Castamatic, Castbox, Castro, Curiocaster, Fountain, Overcast, Pocket Casts, Podcast Addict, Podcast Guru, PodLP, Podverse, TrueFans, Deezer, iHeartRadio, Pandora ja Tune In.',
  },
  {
    question: 'Kuinka usein uusia jaksoja julkaistaan?',
    answer:
      'Julkaisutahti voi aluksi vaihdella, mutta tavoitteena on julkaista uusi jakso joka torstai. Vierasehdotuksia voi lähettää sivuston yhteydenottolomakkeella.',
  },
  {
    question: 'Mistä löydän jaksojen litteroinnit?',
    answer: 'Litteroinnit löytyvät PDF-muodossa Litteroinnit-osiosta sekä yksittäisen jakson sivulta.',
  },
];

const podcastSchema = {
  '@context': 'https://schema.org',
  '@type': 'PodcastSeries',
  name: 'RAAKAA Podcast',
  url: 'https://www.raakaa.fi',
  inLanguage: 'fi',
  description:
    'Sitoutumaton, rehellinen ja kiehtova suomalainen keskusteluohjelma, jossa käsitellään yhteiskuntaa ja ajankohtaisia aiheita.',
  publisher: {
    '@type': 'Person',
    name: 'Markus Suominen',
  },
  sameAs: [
    'https://www.youtube.com/@RaakaaPodcast',
    'https://open.spotify.com/',
    'https://rss.com/podcasts/raakaapodcast/',
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout showHeader={false} fullWidth={true} structuredData={[podcastSchema, faqSchema]}>
  <nav class="home-nav glass">
    <div class="max">
      <a class="logo" href="/">
        <span class="rbox">R</span>
        <span class="word">Raakaa<span class="dot">.</span></span>
      </a>

      <div class="links">
        <a href="#jaksot">Jaksot</a>
        <a href="#markus">Markus</a>
        <a href="#litteroinnit">Litteroinnit</a>
      </div>

      <a class="btn subscribe" href="https://rss.com/podcasts/raakaapodcast/" target="_blank" rel="noreferrer">Kuuntele</a>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-bg">
      <img src="https://images.unsplash.com/photo-1478737270239-2f02b77fc618?q=80&w=2070&auto=format&fit=crop" alt="Podcast studio" />
      <div class="hero-gradient"></div>
    </div>
    <div class="hero-content">
      <p class="eyebrow">Markus Suominen esittää</p>
      <h1>REHELLISTÄ.<br />SUORAA. <span>RAAKAA.</span></h1>
      <div class="actions">
        <a class="btn" href="#jaksot">Kuuntele</a>
        <a class="btn alt" href="#markus">Tarina</a>
      </div>
    </div>
  </section>

  <section id="jaksot" class="episodes max">
    <h2>Uusimmat <span>jaksot</span></h2>
    <div class="episode-grid">
      {episodeSlots.map((episode) =>
        episode ? (
          <article class="ep glass">
            <div class="cover-wrap">
              {episode.imageUrl && <img src={episode.imageUrl} alt={episode.title} loading="lazy" />}
            </div>
            <p class="date">{formatFinnishDate(episode.publishedAt)}</p>
            <h3>{episode.title}</h3>
            <p class="desc">{stripHtml(episode.description).slice(0, 140)}...</p>
            <div class="row">
              <a class="btn small alt" href={`/jaksot/${episode.slug}`}>Avaa</a>
              <button class="btn small" type="button" data-play-episode data-episode-title={episode.title} data-episode-audio={episode.audioUrl}>Toista</button>
            </div>
          </article>
        ) : (
          <article class="ep glass placeholder">
            <div class="cover-wrap empty"></div>
            <p class="date">Tulossa</p>
            <h3>Uusi jakso julkaistaan pian</h3>
            <p class="desc">Tähän ilmestyy seuraava jakso automaattisesti RSS.com-feedistä.</p>
            <div class="row">
              <a class="btn small alt" href="/jaksot">Jaksot</a>
            </div>
          </article>
        ),
      )}
    </div>
  </section>

  <section class="seo max glass">
    <h2>Mikä on <span>RAAKAA Podcast</span>?</h2>
    <p>
      RAAKAA on suomalainen keskustelupodcast, jossa käsitellään yhteiskuntaa, ihmismieltä, ilmiöitä ja
      ajankohtaisia aiheita suoraan ilman turhaa silottelua. Jokainen podcast-jakso julkaistaan RSS.comin kautta,
      ja uudet jaksot nousevat sivulle automaattisesti.
    </p>
    <p>
      Jos etsit suomenkielistä podcastia, jossa annetaan vieraille aikaa, tilaa ja mahdollisuus kertoa oma
      näkökulma rauhassa, RAAKAA tarjoaa juuri tätä: pitkiä, rehellisiä ja syvälle meneviä keskusteluja.
    </p>
  </section>

  <section id="markus" class="markus">
    <div class="max markus-grid">
      <div class="img-wrap">
        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=1000&auto=format&fit=crop" alt="Markus Suominen" />
      </div>
      <div>
        <h4>Juontaja</h4>
        <h3>Markus <span>Suominen</span></h3>
        <p>Markus on elämän koulima joka paikan höylä, joka ymmärtää niin koneita, koodia kuin ihmismieltä. Maailmaa nähnyt seikkailija, joka osaa ottaa tilanteen haltuun paikasta ja seurasta riippumatta.</p>
        <p>Markus on kulkenut polun, joka on vienyt hänet yli 40 maahan, pinnan alle PADI Rescue Diverina, metsään enduropyörällä ja korkeuksiin laskuvarjolla. Tämä elämänkokemus heijastuu kaikkeen tekemiseen.</p>
      </div>
    </div>
  </section>

  <section id="litteroinnit" class="trans max">
    <h2>Saavutettavuus & <span>Litteroinnit</span></h2>
    <p class="muted">Tältä sivulta löydät PDF-litteroinnit. Hallinta onnistuu osoitteessa <a href="/admin">/admin</a>.</p>
    <div class="trans-list">
      {pdfTranscripts.map((item) => (
        <article class="glass tcard">
          <h3>{item.data.title}</h3>
          <p class="date">{item.data.publishDate ?? 'Ei päivämäärää'}</p>
          <p>{item.data.excerpt ?? 'Avaa PDF-litterointi alla olevasta linkistä.'}</p>
          <a class="btn small" href={item.data.pdfUrl} target="_blank" rel="noreferrer">Avaa PDF</a>
        </article>
      ))}
      {pdfTranscripts.length === 0 && <p class="muted">Ei PDF-litterointeja vielä. Lisää ne osoitteessa <a href="/admin">/admin</a>.</p>}
    </div>
  </section>

  <section id="yhteys" class="contact max">
    <h2>Ota <span>yhteyttä</span></h2>
    <p class="muted">Lomake toimii Netlify Forms -integraatiolla. Viesti menee suoraan Netlifyn Forms-näkymään.</p>
    <form class="glass contact-form" name="yhteydenotto" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/kiitos">
      <input type="hidden" name="form-name" value="yhteydenotto" />
      <p class="hidden">
        <label>Älä täytä tätä kenttää: <input name="bot-field" /></label>
      </p>
      <label>
        Nimi
        <input type="text" name="nimi" required />
      </label>
      <label>
        Sähköposti
        <input type="email" name="sahkoposti" required />
      </label>
      <label class="full">
        Viesti
        <textarea name="viesti" rows="5" required></textarea>
      </label>
      <button class="btn full-btn" type="submit">Lähetä viesti</button>
    </form>
  </section>

  <section class="faq max" aria-labelledby="faq-heading">
    <div class="faq-header">
      <h2 id="faq-heading">Usein kysytyt <span>kysymykset</span></h2>
      <a class="btn faq-cta" href="#yhteys">Ehdota vierasta</a>
    </div>
    <p class="faq-intro muted">
      Alla vastaukset luettavassa muodossa. Voit ehdottaa vierasta tai lähettää muun viestin yhteydenottolomakkeella.
    </p>
    <div class="faq-list">
      <article class="glass faq-item">
        <h3>{faqItems[0].question}</h3>
        <p class="faq-answer">{faqItems[0].answer}</p>
      </article>
      <article class="glass faq-item">
        <h3>{faqItems[1].question}</h3>
        <p class="faq-answer">{faqItems[1].answer}</p>
      </article>
      <article class="glass faq-item">
        <h3>{faqItems[2].question}</h3>
        <p class="faq-answer">{faqItems[2].answer}</p>
      </article>
    </div>
  </section>

  <footer class="home-footer">
    <div class="max fwrap">
      <div class="word">Raakaa<span class="dot">.</span></div>
      <div class="socials">
        <a href="https://www.instagram.com/raakaapodcast" target="_blank" rel="noreferrer">Instagram</a>
        <a href="https://www.youtube.com/@RaakaaPodcast" target="_blank" rel="noreferrer">YouTube</a>
        <a href="https://x.com/raakaapodcast" target="_blank" rel="noreferrer">X</a>
      </div>
      <p>© 2026 Raakaa Podcast</p>
    </div>
  </footer>
</BaseLayout>

<style>
  .max { width: min(1120px, 92vw); margin-inline: auto; }
  .home-nav { position: fixed; top: 14px; left: 50%; transform: translateX(-50%); width: min(1120px, 92vw); z-index: 70; }
  .home-nav .max { display: flex; justify-content: space-between; align-items: center; padding: 12px 18px; }
  .logo { display: flex; align-items: center; gap: 8px; font-weight: 800; }
  .rbox { width: 30px; height: 30px; background: var(--accent); color: #111; display: grid; place-items: center; }
  .word { font-size: 1.5rem; text-transform: uppercase; font-weight: 800; letter-spacing: -0.02em; }
  .dot { color: var(--accent); }
  .links { display: flex; gap: 2rem; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.2em; font-weight: 700; }
  .links a:hover, .socials a:hover { color: var(--accent); }
  .subscribe { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.12em; padding: 0.6rem 1rem; }
  .hero { position: relative; height: 100svh; display: grid; place-items: center; overflow: hidden; width: 100%; }
  .hero-bg { position: absolute; inset: 0; }
  .hero-bg img { width: 100%; height: 100%; object-fit: cover; opacity: 0.2; transform: scale(1.05); }
  .hero-gradient { position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(250, 204, 21, 0.05) 0%, rgba(10, 10, 10, 1) 100%); }
  .hero-content { position: relative; z-index: 1; text-align: center; padding: 0 1rem; }
  .eyebrow { color: var(--accent); text-transform: uppercase; letter-spacing: 0.35em; font-size: 0.75rem; font-weight: 700; margin-bottom: 1rem; }
  h1 { margin: 0; font-size: clamp(2.6rem, 10vw, 7rem); line-height: 0.95; font-weight: 900; letter-spacing: -0.02em; }
  h1 span, h2 span, .markus h3 span { color: var(--accent); }
  .actions { margin-top: 1.6rem; display: flex; justify-content: center; gap: 0.9rem; flex-wrap: wrap; }
  .btn.alt { background: rgba(255, 255, 255, 0.08); color: #fff; border: 1px solid var(--border); }
  .episodes, .trans { padding: 6rem 0; }
  .episodes h2, .trans h2 { font-size: clamp(2rem, 5vw, 3.6rem); font-style: italic; text-transform: uppercase; margin: 0 0 1.5rem; }
  .episode-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 1rem; }
  .ep { padding: 1rem; }
  .ep:hover { border-color: rgba(255,212,0,0.4); }
  .placeholder { opacity: 0.86; }
  .cover-wrap { aspect-ratio: 1/1; overflow: hidden; margin-bottom: 0.8rem; }
  .cover-wrap.empty { background: rgba(255, 255, 255, 0.05); border: 1px dashed var(--border); }
  .cover-wrap img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1); transition: 220ms; display: block; }
  .ep:hover .cover-wrap img { filter: grayscale(0); transform: scale(1.03); }
  .date { color: var(--accent); text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.15em; font-weight: 700; }
  .ep h3 { margin: 0.35rem 0 0.5rem; font-size: 1.25rem; }
  .desc { color: var(--muted); margin: 0; }
  .row { display: flex; gap: 0.5rem; margin-top: 0.9rem; }
  .small { padding: 0.55rem 0.9rem; font-size: 0.85rem; }
  .markus { padding: 6rem 0; background: #0f0f0f; }
  .markus-grid { display: grid; gap: 2rem; grid-template-columns: repeat(2, minmax(0, 1fr)); align-items: center; }
  .img-wrap img { width: 100%; border: 1px solid var(--border); filter: grayscale(1); }
  .markus h4 { color: var(--accent); text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.72rem; margin: 0 0 0.6rem; }
  .markus h3 { margin: 0 0 1rem; font-size: clamp(2rem, 5vw, 3.2rem); text-transform: uppercase; font-style: italic; }
  .markus p { color: var(--muted); line-height: 1.7; }
  .trans-list { display: grid; gap: 0.8rem; margin-top: 1rem; }
  .tcard { padding: 1rem; }
  .home-footer { border-top: 1px solid rgba(255,255,255,0.08); padding: 2.2rem 0; margin-bottom: 6rem; width: 100%; }
  .fwrap { display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .socials { display: flex; gap: 1rem; font-size: 0.9rem; color: var(--muted); }
  .home-footer p { color: #6e6e6e; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; margin: 0; }
  .contact { padding: 2rem 0 5rem; }
  .contact h2 { font-size: clamp(2rem, 5vw, 3.6rem); font-style: italic; text-transform: uppercase; margin: 0 0 0.8rem; }
  .contact-form {
    margin-top: 1rem;
    padding: 1rem;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }
  .hidden { display: none; }
  label { display: flex; flex-direction: column; gap: 0.4rem; font-size: 0.92rem; color: var(--muted); }
  input, textarea {
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    padding: 0.8rem 0.9rem;
    font: inherit;
  }
  .full { grid-column: 1 / -1; }
  .full-btn { justify-self: start; }
  .seo {
    padding: 1.1rem;
    margin-top: 1rem;
    margin-bottom: 2rem;
  }
  .seo h2 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    margin: 0 0 0.8rem;
  }
  .seo p {
    color: var(--muted);
    margin: 0.65rem 0;
    line-height: 1.7;
  }
  .faq {
    padding: 0 0 5rem;
    max-width: 720px;
    margin-inline: auto;
  }
  .faq-header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem 1.5rem;
    margin-bottom: 0.75rem;
  }
  .faq h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-style: italic;
    text-transform: uppercase;
    margin: 0;
    line-height: 1.1;
    max-width: 20ch;
  }
  .faq-cta {
    flex-shrink: 0;
    font-size: 0.8rem;
    padding: 0.65rem 1.15rem;
  }
  .faq-intro {
    margin: 0 0 1.75rem;
    font-size: 1rem;
    line-height: 1.65;
    max-width: 65ch;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .faq-item {
    padding: clamp(1.15rem, 2.5vw, 1.6rem);
  }
  .faq-item h3 {
    margin: 0 0 0.85rem;
    font-size: clamp(1.05rem, 2.2vw, 1.2rem);
    font-weight: 800;
    line-height: 1.35;
    color: var(--text);
  }
  .faq-answer {
    margin: 0;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.75;
    max-width: 65ch;
  }
  @media (max-width: 900px) {
    .links { display: none; }
    .markus-grid { grid-template-columns: 1fr; }
    .home-nav { top: 8px; }
    .contact-form { grid-template-columns: 1fr; }
    .episode-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (max-width: 680px) {
    .episode-grid { grid-template-columns: 1fr; }
  }
</style>
