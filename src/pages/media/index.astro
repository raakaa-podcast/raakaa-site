---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getMediaKitSnapshot } from '../../lib/mediaKit';
import { formatFinnishDate } from '../../lib/rss';

const title = 'Media kit | RAAKAA Podcast';
const description =
  'RAAKAA Podcastin media kit: suomalainen keskusteluohjelma, julkaisut ja alustaluvut yhdellä sivulla. Sopii vieraille, yhteistyökumppaneille ja taustoitukseen.';

const snapshot = await getMediaKitSnapshot();

const numberFmt = new Intl.NumberFormat('fi-FI');
const decFmt = new Intl.NumberFormat('fi-FI', { maximumFractionDigits: 1 });
const compactFmt = new Intl.NumberFormat('fi-FI', { notation: 'compact', maximumFractionDigits: 1 });

const formatNumber = (value: number | null) => (value === null ? '—' : numberFmt.format(value));
const formatCompact = (value: number | null) => (value === null ? '—' : compactFmt.format(value));
const formatDecimal = (value: number | null) => (value === null ? '—' : decFmt.format(value));

const lastUpdated = formatFinnishDate(snapshot.generatedAt);
const latestReleaseDate = snapshot.latestEpisodeDate ? formatFinnishDate(snapshot.latestEpisodeDate) : '—';
---

<BaseLayout title={title} description={description} noindex>
  <div class="page max">
    <article class="media-kit glass">
      <header class="head">
        <p class="eyebrow">Podcast media kit</p>
        <h1>RAAKAA Podcast — Media kit</h1>
        <p class="lede">
          RAAKAA on suomalainen keskustelupodcast, jossa käydään pitkiä, syvällisiä keskusteluja yhteiskunnasta,
          ihmismielestä ja ajankohtaisista ilmiöistä — ilman pintaraapaisua ja turhaa silottelua. Tällä sivulla näet
          nopeasti ohjelman luonteen, julkaisujen mittakaavan ja tavoittavuuden eri alustoilla, jotta tiedät mitä
          vierailusi tai yhteistyösi koskee.
        </p>
        <p class="stamp muted">Päivitetty: {lastUpdated}</p>
      </header>

      <section class="stats" aria-labelledby="sec-stats">
        <h2 id="sec-stats">Yleisö ja tuotanto yhdellä silmäyksellä</h2>
        <div class="stat-grid">
          <article class="stat-card">
            <p class="stat-label">Jaksot yhteensä</p>
            <p class="stat-value">{formatNumber(snapshot.totalEpisodes)}</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Kesto yhteensä</p>
            <p class="stat-value">{formatNumber(snapshot.totalRuntimeMinutes)} min</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Keskimääräinen jakso</p>
            <p class="stat-value">{formatDecimal(snapshot.avgEpisodeMinutes)} min</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Julkaisuja 30 päivässä</p>
            <p class="stat-value">{formatNumber(snapshot.releasesLast30Days)}</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Uniikkeja vieraita</p>
            <p class="stat-value">{formatNumber(snapshot.uniqueGuests)}</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Aihekategorioita</p>
            <p class="stat-value">{formatNumber(snapshot.uniqueTopics)}</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Videojaksoja</p>
            <p class="stat-value">{formatNumber(snapshot.episodesWithYoutube)}</p>
          </article>
          <article class="stat-card">
            <p class="stat-label">Viimeisin julkaisu</p>
            <p class="stat-value stat-date">{latestReleaseDate}</p>
          </article>
        </div>
      </section>

      <section aria-labelledby="sec-platforms">
        <h2 id="sec-platforms">Alustat ja tavoittavuus</h2>
        <div class="platform-grid">
          <article class="platform-card">
            <h3>Spotify</h3>
            <p><strong>Seuraajat:</strong> {formatCompact(snapshot.platform.spotifyFollowers)}</p>
            <p><strong>Kuukausikuuntelijat:</strong> {formatCompact(snapshot.platform.spotifyMonthlyListeners)}</p>
          </article>
          <article class="platform-card">
            <h3>YouTube</h3>
            <p><strong>Tilaajat:</strong> {formatCompact(snapshot.platform.youtubeSubscribers)}</p>
            <p><strong>Katselut yhteensä:</strong> {formatCompact(snapshot.platform.youtubeViews)}</p>
          </article>
          <article class="platform-card">
            <h3>Apple Podcasts</h3>
            <p><strong>Arvosana:</strong> {formatDecimal(snapshot.platform.appleRating)} / 5</p>
            <p><strong>Arvioiden määrä:</strong> {formatNumber(snapshot.platform.appleRatingsCount)}</p>
          </article>
        </div>
      </section>

      <section aria-labelledby="sec-show">
        <h2 id="sec-show">Mikä RAAKAA on vieraalle</h2>
        <ul class="bullets">
          <li>Suomenkielinen keskusteluohjelma, jossa aiheita käsitellään pitkässä muodossa ilman pintaraapaisua.</li>
          <li>Vieras saa aikaa ajatella, tarkentaa ja perustella; keskustelu rakentuu kuuntelemisen varaan.</li>
          <li>Tavoite on tehdä vaikeista ilmiöistä ymmärrettäviä yleiskielellä ilman sisältöjen latistamista.</li>
          <li>Isäntä: <strong>Markus Suominen</strong>.</li>
        </ul>
      </section>

      <section aria-labelledby="sec-guest">
        <h2 id="sec-guest">Miksi tulla vieraaksi</h2>
        <ul class="bullets">
          <li>Asiantuntijalle tilaa avata aihe syvemmin kuin uutisotsikoissa tai lyhyissä someformaateissa.</li>
          <li>Jakso toimii vieraan referenssinä pitkään julkaisun jälkeenkin.</li>
          <li>Aihelandingit (`/jaksot/tag/*`) nostavat jaksoja myös orgaanisessa haussa.</li>
        </ul>
      </section>

      <p class="contact">
        Yhteydenotot, vierasehdotukset ja yhteistyö: <a href="/">raakaa.fi</a> (yhteydenottolomake).
      </p>
    </article>
  </div>
</BaseLayout>

<style>
  .page {
    padding-top: 7rem;
    padding-bottom: 2rem;
  }

  .media-kit {
    padding: clamp(1.2rem, 3vw, 2.2rem);
    max-width: 72rem;
  }

  .head {
    margin-bottom: 1.75rem;
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
    color: var(--muted);
  }

  h1 {
    margin: 0 0 0.6rem;
    font-size: clamp(1.85rem, 4vw, 2.75rem);
  }

  .lede {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
    font-size: 1rem;
  }

  .stamp {
    margin: 0.8rem 0 0;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  section {
    margin-bottom: 2rem;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .stats {
    margin-top: 1.25rem;
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.7rem;
  }

  .stat-card {
    margin: 0;
    padding: 0.9rem 0.95rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.03);
  }

  .stat-label {
    margin: 0 0 0.4rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--muted);
    font-weight: 700;
  }

  .stat-value {
    margin: 0;
    font-size: clamp(1.2rem, 2.6vw, 1.55rem);
    line-height: 1.1;
    font-weight: 800;
  }

  .stat-date {
    font-size: 1rem;
    line-height: 1.3;
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.7rem;
  }

  .platform-card {
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.9rem 0.95rem;
  }

  .platform-card h3 {
    margin: 0 0 0.55rem;
    font-size: 1rem;
  }

  .platform-card p {
    margin: 0 0 0.3rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .bullets {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .bullets li {
    margin-bottom: 0.45rem;
  }

  .contact {
    margin: 2rem 0 0;
    font-size: 1rem;
    color: var(--text);
  }

  .contact a {
    color: var(--accent);
  }
</style>
