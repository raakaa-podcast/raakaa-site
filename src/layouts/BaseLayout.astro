---
import { ClientRouter } from 'astro:transitions';
import StickyPlayer from '../components/StickyPlayer.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title = 'RAAKAA Podcast – suomalainen keskustelupodcast | Markus Suominen',
  description = 'RAAKAA Podcast on sitoutumaton, rehellinen ja kiehtova suomalainen keskusteluohjelma. Pitkät keskustelut yhteiskunnasta, ihmismielestä ja ajankohtaisista aiheista. Kuuntele Spotifyssa, Apple Podcastsissa ja YouTubessa.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  noindex = false,
  structuredData,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.raakaa.fi';
const canonical = new URL(Astro.url.pathname, siteUrl).toString().replace(/\/$/, '') || siteUrl;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#070707" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="RAAKAA Podcast RSS" href="https://media.rss.com/raakaapodcast/feed.xml" />

    <link rel="preconnect" href="https://media.rss.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://player.rss.com" />

    <meta property="og:site_name" content="RAAKAA Podcast" />
    <meta property="og:locale" content="fi_FI" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="keywords" content="podcast, suomalainen podcast, keskustelupodcast, RAAKAA, Markus Suominen, suomi, yhteiskunta, ajankohtaista, haastattelu, suomenkielinen podcast" />
    <meta name="author" content="Markus Suominen" />
    <meta name="publisher" content="RAAKAA Podcast" />

    {
      structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)} />
      ))
    }
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <a class="skip-link" href="#main">Siirry pääsisältöön</a>

    <SiteHeader />

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <SiteFooter />

    <StickyPlayer />
  </body>
</html>

<style is:global>
  :root {
    --bg: #070707;
    --surface: rgba(18, 18, 18, 0.62);
    --surface-strong: rgba(20, 20, 20, 0.82);
    --text: #f7f7f7;
    --muted: #bcbcbc;
    --accent: #ffd400;
    --accent-dark: #e3bd00;
    --border: rgba(255, 255, 255, 0.16);
    --radius: 18px;
    --shadow: 0 10px 35px rgba(0, 0, 0, 0.35);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(1200px 600px at 85% -5%, rgba(255, 212, 0, 0.14), transparent 65%),
      radial-gradient(900px 500px at -10% 20%, rgba(255, 255, 255, 0.06), transparent 60%),
      var(--bg);
    color: var(--text);
    font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    overflow-x: clip;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-bottom: 6rem;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  /* Saavutettava näppäinfokus */
  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .btn:focus-visible,
  button:focus-visible {
    outline-offset: 3px;
  }

  main {
    min-height: 60vh;
    padding-bottom: clamp(10rem, 22vh, 15rem);
  }

  main:focus {
    outline: none;
  }

  .container,
  .max {
    width: min(1120px, 92vw);
    margin-inline: auto;
  }

  .glass {
    border: 1px solid var(--border);
    background: var(--surface);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .section-title {
    font-size: clamp(1.5rem, 2.3vw, 2.2rem);
    margin: 0 0 1rem;
  }

  .muted {
    color: var(--muted);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--accent);
    color: #161616;
    border: 0;
    border-radius: 999px;
    font-weight: 700;
    padding: 0.75rem 1.2rem;
    cursor: pointer;
    transition: background 150ms ease, transform 150ms ease;
  }

  .btn:hover {
    background: var(--accent-dark);
  }

  .btn.alt {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    border: 1px solid var(--border);
  }

  .btn.alt:hover {
    background: rgba(255, 255, 255, 0.16);
  }

  .btn.small {
    padding: 0.55rem 0.9rem;
    font-size: 0.85rem;
  }

  .skip-link {
    position: absolute;
    left: -10000px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .skip-link:focus {
    left: 16px;
    top: 16px;
    width: auto;
    height: auto;
    background: var(--accent);
    color: #111;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    z-index: 200;
  }

  .sticky-player {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateZ(0);
    z-index: 40;
    /* Reserve space so fixed bar does not cover footer legal links */
    padding-bottom: env(safe-area-inset-bottom, 0px);
    padding: 10px 0 14px;
    width: min(1120px, 92vw);
    will-change: transform;
    contain: layout paint;
  }

  .player-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background: var(--surface-strong);
    border: 1px solid rgba(255, 212, 0, 0.2);
  }

  .track-label {
    margin: 0;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .track-title {
    margin: 0.2rem 0 0;
    font-weight: 700;
  }

  .controls {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: 0.65rem;
  }

  .play-btn {
    border: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--accent);
    color: #111;
    font-weight: 700;
    cursor: pointer;
  }

  .time {
    font-size: 0.82rem;
    color: var(--muted);
    min-width: 2.6rem;
  }

  input[type='range'] {
    accent-color: var(--accent);
    width: 100%;
  }

  input[type='range']:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }
</style>
