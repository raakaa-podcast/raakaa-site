---
import StickyPlayer from '../components/StickyPlayer.astro';

type Props = {
  title?: string;
  description?: string;
  showHeader?: boolean;
  fullWidth?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
};

const {
  title = 'RAAKAA Podcast - Kiehtova suomalainen keskusteluohjelma',
  description = 'Sitoutumaton, rehellinen ja kiehtova suomalainen podcast.',
  showHeader = true,
  fullWidth = false,
  structuredData,
} = Astro.props;

const structuredDataItems = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {
      structuredDataItems.map((item) => (
        <script type="application/ld+json" set:html={JSON.stringify(item)}></script>
      ))
    }
  </head>
  <body>
    {
      showHeader && (
        <header class="site-header glass">
          <div class="container nav-content">
            <a class="brand" href="/">RAAKAA</a>
            <nav>
              <ul>
                <li><a href="/">Etusivu</a></li>
                <li><a href="/jaksot">Jaksot</a></li>
                <li><a href="/admin">Transcriptit</a></li>
              </ul>
            </nav>
          </div>
        </header>
      )
    }

    <main class:list={[fullWidth ? 'main-full' : 'container']}>
      <slot />
    </main>

    <StickyPlayer />
  </body>
</html>

<style is:global>
  :root {
    --bg: #070707;
    --surface: rgba(18, 18, 18, 0.62);
    --surface-strong: rgba(20, 20, 20, 0.82);
    --text: #f7f7f7;
    --muted: #bcbcbc;
    --accent: #ffd400;
    --accent-dark: #e3bd00;
    --border: rgba(255, 255, 255, 0.16);
    --radius: 18px;
    --shadow: 0 10px 35px rgba(0, 0, 0, 0.35);
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(1200px 600px at 85% -5%, rgba(255, 212, 0, 0.14), transparent 65%),
      radial-gradient(900px 500px at -10% 20%, rgba(255, 255, 255, 0.06), transparent 60%),
      var(--bg);
    color: var(--text);
    font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
    overflow-x: clip;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    width: min(1120px, 92vw);
    margin-inline: auto;
  }

  .glass {
    border: 1px solid var(--border);
    background: var(--surface);
    backdrop-filter: blur(16px);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .site-header {
    position: sticky;
    top: 10px;
    z-index: 30;
    margin: 10px auto 24px;
    width: min(1120px, 92vw);
  }

  .nav-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
  }

  .brand {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  nav ul {
    display: flex;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  nav a {
    color: var(--muted);
    font-weight: 600;
  }

  nav a:hover {
    color: var(--accent);
  }

  .section-title {
    font-size: clamp(1.5rem, 2.3vw, 2.2rem);
    margin: 0 0 1rem;
  }

  main.container {
    padding-bottom: 8.5rem;
  }

  main.main-full {
    width: 100%;
    padding-bottom: 8.5rem;
  }

  .muted {
    color: var(--muted);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--accent);
    color: #161616;
    border: 0;
    border-radius: 999px;
    font-weight: 700;
    padding: 0.75rem 1.2rem;
    cursor: pointer;
  }

  .btn:hover {
    background: var(--accent-dark);
  }

  .sticky-player {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 40;
    padding: 10px 0 14px;
    width: min(1120px, 92vw);
  }

  .player-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 0.8rem;
    padding: 0.8rem 1rem;
    background: var(--surface-strong);
    border: 1px solid rgba(255, 212, 0, 0.2);
  }

  .track-label {
    margin: 0;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .track-title {
    margin: 0.2rem 0 0;
    font-weight: 700;
  }

  .controls {
    display: grid;
    grid-template-columns: auto auto 1fr auto;
    align-items: center;
    gap: 0.65rem;
  }

  .play-btn {
    border: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--accent);
    color: #111;
    font-weight: 700;
    cursor: pointer;
  }

  .time {
    font-size: 0.82rem;
    color: var(--muted);
    min-width: 2.6rem;
  }

  input[type='range'] {
    accent-color: var(--accent);
    width: 100%;
  }

  @media (max-width: 720px) {
    .nav-content {
      flex-direction: column;
      gap: 0.5rem;
    }

    nav ul {
      flex-wrap: wrap;
      justify-content: center;
    }

    main.container {
      padding-bottom: 9.5rem;
    }
  }
</style>
