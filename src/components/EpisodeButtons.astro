---
type Props = {
  slug: string;
  title: string;
  audioUrl: string;
  pdfUrl?: string | null;
  size?: 'small' | 'default';
};

const { slug, title, audioUrl, pdfUrl, size = 'small' } = Astro.props;
const cls = size === 'small' ? 'btn small' : 'btn';
---

<div class="episode-buttons">
  <a
    class={`${cls} alt`}
    href={`/jaksot/${slug}`}
    aria-label={`Avaa jakso: ${title}`}
  >
    <span aria-hidden="true">Avaa</span>
  </a>
  <button
    class={cls}
    type="button"
    data-play-episode
    data-episode-title={title}
    data-episode-audio={audioUrl}
    aria-label={`Toista jakso: ${title}`}
  >
    <span aria-hidden="true">Toista</span>
  </button>
  {pdfUrl && (
    <a
      class={`${cls} alt`}
      href={pdfUrl}
      target="_blank"
      rel="noreferrer noopener"
      aria-label={`Avaa litterointi PDF-muodossa uudessa välilehdessä: ${title}`}
    >
      <span aria-hidden="true">Litterointi</span>
    </a>
  )}
</div>

<style>
  .episode-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
