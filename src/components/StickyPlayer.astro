---
export type StickyInitialEpisode = {
  title: string;
  audioUrl: string;
  imageUrl?: string;
  slug: string;
};

type Props = {
  initialEpisode?: StickyInitialEpisode | null;
};

const { initialEpisode = null } = Astro.props;

const dataInitialTitle = initialEpisode?.title ?? '';
const dataInitialAudio = initialEpisode?.audioUrl ?? '';
const dataInitialArt = initialEpisode?.imageUrl ?? '';
const dataInitialSlug = initialEpisode?.slug ?? '';
---

<div
  id="sticky-player"
  class="sticky-player"
  role="region"
  aria-label="Äänisoitin"
  data-initial-title={dataInitialTitle}
  data-initial-audio={dataInitialAudio}
  data-initial-art={dataInitialArt}
  data-initial-slug={dataInitialSlug}
  transition:persist="raakaa-sticky-player"
>
  <div class="player-inner glass">
    <div class="player-main">
      <div class="track-art-wrap" aria-hidden="true">
        <img
          id="track-art"
          class="track-art"
          src={initialEpisode?.imageUrl ?? ''}
          alt=""
          width="56"
          height="56"
          decoding="async"
          hidden={!initialEpisode?.imageUrl}
        />
        <div
          id="track-art-placeholder"
          class="track-art-placeholder"
          aria-hidden="true"
          hidden={Boolean(initialEpisode?.imageUrl)}
        >
          <span>R</span>
        </div>
      </div>

      <div class="track-block">
        <p class="track-label">Nyt soi</p>
        <p class="track-title-row">
          <a
            id="track-title-link"
            class="track-title-link"
            href={initialEpisode?.slug ? `/jaksot/${initialEpisode.slug}` : '#'}
            hidden={!initialEpisode?.slug}
          >
            {initialEpisode?.slug ? initialEpisode.title : ''}
          </a>
          <span id="track-title-plain" class="track-title" hidden={Boolean(initialEpisode?.slug)}>
            {initialEpisode?.slug ? '' : initialEpisode?.title ?? 'Valitse jakso kuunneltavaksi'}
          </span>
        </p>

        <div class="scrub-row">
          <span id="time-current" class="time" aria-label="Kulunut aika">00:00</span>
          <input
            id="seek"
            type="range"
            min="0"
            max="100"
            step="0.1"
            value="0"
            aria-label="Toistopaikka"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
          />
          <span id="time-duration" class="time" aria-label="Jakson kesto">00:00</span>
        </div>
      </div>

      <button
        id="toggle-play"
        class="play-btn"
        type="button"
        aria-label="Toista"
        aria-pressed="false"
      >
        <span aria-hidden="true">▶</span>
      </button>
    </div>

    <p
      id="playback-announcer"
      class="sr-only"
      role="status"
      aria-live="polite"
      aria-atomic="true"
    ></p>

    <audio id="audio-element" preload="none"></audio>
  </div>
</div>

<script>
  const root = document.getElementById('sticky-player');
  const audio = document.getElementById('audio-element');
  const trackTitlePlain = document.getElementById('track-title-plain');
  const trackTitleLink = document.getElementById('track-title-link');
  const trackArt = document.getElementById('track-art');
  const trackArtPlaceholder = document.getElementById('track-art-placeholder');
  const togglePlay = document.getElementById('toggle-play');
  const seek = document.getElementById('seek');
  const timeCurrent = document.getElementById('time-current');
  const timeDuration = document.getElementById('time-duration');
  const announcer = document.getElementById('playback-announcer');

  if (
    root &&
    audio &&
    trackTitlePlain &&
    trackTitleLink &&
    trackArt &&
    trackArtPlaceholder &&
    togglePlay &&
    seek &&
    timeCurrent &&
    timeDuration &&
    announcer
  ) {
    const formatTime = (seconds) => {
      if (!Number.isFinite(seconds)) return '00:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
    };

    const playIcon = togglePlay.querySelector('span') || togglePlay;

    const setPlayingState = (playing) => {
      playIcon.textContent = playing ? '❚❚' : '▶';
      togglePlay.setAttribute('aria-pressed', playing ? 'true' : 'false');
      togglePlay.setAttribute('aria-label', playing ? 'Pysäytä' : 'Toista');
    };

    const setArtwork = (url) => {
      const trimmed = (url || '').trim();
      if (trimmed) {
        trackArt.src = trimmed;
        trackArt.alt = '';
        trackArt.hidden = false;
        trackArtPlaceholder.hidden = true;
      } else {
        trackArt.removeAttribute('src');
        trackArt.alt = '';
        trackArt.hidden = true;
        trackArtPlaceholder.hidden = false;
      }
    };

    const setTitleDisplay = (title, slug) => {
      const text = title || 'Tuntematon jakso';
      if (slug) {
        trackTitleLink.textContent = text;
        trackTitleLink.href = `/jaksot/${slug}`;
        trackTitleLink.hidden = false;
        trackTitlePlain.hidden = true;
      } else {
        trackTitlePlain.textContent = text;
        trackTitlePlain.hidden = false;
        trackTitleLink.hidden = true;
      }
    };

    const getAnnouncerTitle = () => {
      if (!trackTitleLink.hidden) return trackTitleLink.textContent?.trim() || '';
      return trackTitlePlain.textContent?.trim() || '';
    };

    let seeking = false;

    const setTrack = (title, src, artUrl, slug) => {
      if (!src) return;
      const changed = audio.src !== src;
      if (changed) {
        audio.src = src;
        audio.preload = 'metadata';
        seek.value = '0';
        seek.setAttribute('aria-valuenow', '0');
        timeCurrent.textContent = '00:00';
        timeDuration.textContent = '00:00';
      }
      setTitleDisplay(title, slug || '');
      setArtwork(artUrl);
    };

    document.addEventListener('click', async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const button = target.closest('[data-play-episode]');
      if (!(button instanceof HTMLElement)) return;

      const title = button.dataset.episodeTitle || 'Tuntematon jakso';
      const src = button.dataset.episodeAudio || '';
      const artUrl = button.dataset.episodeArt?.trim() || '';
      const slug = button.dataset.episodeSlug?.trim() || '';
      setTrack(title, src, artUrl, slug);

      try {
        await audio.play();
        setPlayingState(true);
      } catch (err) {
        console.error('Playback failed', err);
      }
    });

    togglePlay.addEventListener('click', async () => {
      if (!audio.src) return;
      if (audio.paused) {
        await audio.play();
        setPlayingState(true);
      } else {
        audio.pause();
        setPlayingState(false);
      }
    });

    audio.addEventListener('loadedmetadata', () => {
      timeDuration.textContent = formatTime(audio.duration);
    });

    audio.addEventListener('timeupdate', () => {
      if (seeking) return;
      const progress = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
      seek.value = String(progress);
      seek.setAttribute('aria-valuenow', progress.toFixed(1));
      timeCurrent.textContent = formatTime(audio.currentTime);
      if (Number.isFinite(audio.duration)) {
        timeDuration.textContent = formatTime(audio.duration);
      }
    });

    audio.addEventListener('play', () => {
      const title = getAnnouncerTitle() || 'tuntematon jakso';
      announcer.textContent = `Nyt soi: ${title}`;
    });

    audio.addEventListener('ended', () => {
      setPlayingState(false);
      seek.setAttribute('aria-valuenow', '0');
    });

    audio.addEventListener('pause', () => {
      setPlayingState(false);
    });

    seek.addEventListener('pointerdown', () => {
      seeking = true;
    });
    window.addEventListener(
      'pointerup',
      () => {
        seeking = false;
      },
      { capture: true },
    );

    seek.addEventListener('input', () => {
      if (!audio.duration) return;
      audio.currentTime = (Number(seek.value) / 100) * audio.duration;
      timeCurrent.textContent = formatTime(audio.currentTime);
    });

    const initTitle = root.dataset.initialTitle?.trim() || '';
    const initAudio = root.dataset.initialAudio?.trim() || '';
    const initArt = root.dataset.initialArt?.trim() || '';
    const initSlug = root.dataset.initialSlug?.trim() || '';

    if (initAudio) {
      setTrack(initTitle || 'Tuntematon jakso', initAudio, initArt, initSlug);
    } else {
      setArtwork('');
      if (!initTitle) {
        setTitleDisplay('Valitse jakso kuunneltavaksi', '');
      }
    }
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
