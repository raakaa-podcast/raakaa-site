---
type IconName =
  | 'instagram'
  | 'youtube'
  | 'x'
  | 'spotify'
  | 'apple'
  | 'rss'
  | 'tiktok'
  | 'facebook'
  | 'whatsapp'
  | 'linkedin'
  | 'link'
  | 'check'
  | 'iframe';

type Props = {
  name: IconName;
  size?: number;
  title?: string;
};

const { name, size = 18, title } = Astro.props;
