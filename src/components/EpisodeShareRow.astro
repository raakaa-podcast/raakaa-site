---
import SocialIcons from './SocialIcons.astro';

type Props = {
  title: string;
  url: string;
  /** Kun annettu, näytetään upotus Jaa-rivillä. */
  slug?: string;
};

const { title, url, slug } = Astro.props;

const whatsAppHref = `https://wa.me/?text=${encodeURIComponent(`${title} ${url}`)}`;
const xHref = `https://x.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const linkedInHref = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;

const iconSize = 20;

const base = Astro.site ?? new URL('https://www.raakaa.fi');
const embedPageUrl = slug
  ? new URL(`/jaksot/${slug}/embed`, base).href.replace(/\/$/, '')
  : '';
const escapeAttr = (s: string) =>
  s.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
const iframeSnippet =
  slug && embedPageUrl
    ? `<iframe\n  src="${embedPageUrl}"\n  width="100%"\n  height="180"\n  frameborder="0"\n  title="${escapeAttr(title)}"\n  allow="autoplay">\n</iframe>`
    : '';
const snippetFieldId = slug ? `embed-code-${slug}` : '';
---

<div class="episode-share" id="episode-share" aria-label="Jaa jakso">
  <p class="share-label">Jaa</p>
  <div class="share-row">
    <a
      class="share-btn"
      href={whatsAppHref}
      target="_blank"
      rel="noopener noreferrer"
      title="Jaa WhatsAppissa"
      aria-label="Jaa WhatsAppissa"
    >
      <SocialIcons name="whatsapp" size={iconSize} />
    </a>
    <a
      class="share-btn"
      href={xHref}
      target="_blank"
      rel="noopener noreferrer"
      title="Jaa X:ssä"
      aria-label="Jaa X:ssä"
    >
      <SocialIcons name="x" size={iconSize} />
    </a>
    <a
      class="share-btn"
      href={linkedInHref}
      target="_blank"
      rel="noopener noreferrer"
      title="Jaa LinkedInissä"
      aria-label="Jaa LinkedInissä"
    >
      <SocialIcons name="linkedin" size={iconSize} />
    </a>
    <button
      type="button"
      class="share-btn share-instagram"
      data-share-instagram
      data-share-episode-title={title}
      data-share-episode-url={url}
      title="Jaa Instagramissa"
      aria-label="Jaa Instagramissa (kopioi teksti tai jakovalikko)"
    >
      <SocialIcons name="instagram" size={iconSize} />
    </button>
    <button
      type="button"
      class="share-btn share-copy"
      data-share-copy
      data-share-url={url}
      title="Kopioi linkki"
      aria-label="Kopioi linkki"
    >
      <span class="share-copy__idle" aria-hidden="true">
        <SocialIcons name="link" size={iconSize} />
      </span>
      <span class="share-copy__done" aria-hidden="true" hidden>
        <SocialIcons name="check" size={iconSize} />
      </span>
    </button>

    {
      slug && snippetFieldId && (
        <details class="share-embed">
          <summary
            class="share-btn share-embed__summary"
            title="Upota jakso"
            aria-label="Upota jakso"
          >
            <SocialIcons name="iframe" size={iconSize} />
            <span class="share-embed__label">Upota</span>
          </summary>
          <div class="share-embed__panel glass">
            <label class="embed-label" for={snippetFieldId}>HTML-upotuskoodi</label>
            <div class="embed-toolbar">
              <textarea
                id={snippetFieldId}
                class="embed-snippet"
                readonly
                rows={8}
                aria-describedby="embed-snippet-hint">{iframeSnippet}</textarea>
              <div class="embed-actions">
                <button type="button" class="btn embed-copy" data-embed-copy>
                  Kopioi koodi
                </button>
                <a
                  class="btn alt embed-demo"
                  href="/demo/upotus"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Avaa upotetun soittimen demoesimerkki uuteen välilehteen"
                >
                  Näytä demo
                </a>
              </div>
            </div>
            <p id="embed-snippet-hint" class="embed-hint muted">
              Liitä koodi sivustollesi. Soitin toimii upotuksessa ilman pääsivuston valikkoa.
            </p>
            <p class="embed-copy-toast" data-embed-toast role="status" aria-live="polite" aria-atomic="true" hidden></p>
          </div>
        </details>
      )
    }
  </div>
  <div
    class="share-toast"
    data-share-toast
    role="status"
    aria-live="polite"
    aria-atomic="true"
    hidden
  ></div>
</div>

<script>
  (function () {
    var root = document.getElementById('episode-share');
    if (!root) return;
    var btn = root.querySelector('[data-share-copy]');
    var toast = root.querySelector('[data-share-toast]');
    if (!btn || !(btn instanceof HTMLButtonElement) || !toast) return;

    var idle = btn.querySelector('.share-copy__idle');
    var done = btn.querySelector('.share-copy__done');
    var url = btn.getAttribute('data-share-url') || '';
    var copyTimer = 0;
    var iconTimer = 0;

    function showToast() {
      toast.textContent = 'Kopioitu!';
      toast.hidden = false;
      window.clearTimeout(copyTimer);
      copyTimer = window.setTimeout(function () {
        toast.textContent = '';
        toast.hidden = true;
      }, 2600);
    }

    function setCopiedState(on) {
      btn.classList.toggle('is-copied', on);
      if (idle) idle.hidden = on;
      if (done) done.hidden = !on;
      if (on) {
        btn.setAttribute('aria-label', 'Linkki kopioitu');
      } else {
        btn.setAttribute('aria-label', 'Kopioi linkki');
      }
    }

    btn.addEventListener('click', function () {
      function fallbackCopy(text) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
          showToast();
          setCopiedState(true);
          window.clearTimeout(iconTimer);
          iconTimer = window.setTimeout(function () {
            setCopiedState(false);
          }, 2000);
        } catch (_) {}
        document.body.removeChild(ta);
      }

      if (!url) return;

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard
          .writeText(url)
          .then(function () {
            showToast();
            setCopiedState(true);
            window.clearTimeout(iconTimer);
            iconTimer = window.setTimeout(function () {
              setCopiedState(false);
            }, 2000);
          })
          .catch(function () {
            fallbackCopy(url);
          });
      } else {
        fallbackCopy(url);
      }
    });
  })();
</script>

<script>
  (function () {
    var root = document.getElementById('episode-share');
    if (!root) return;
    var igBtn = root.querySelector('[data-share-instagram]');
    var toast = root.querySelector('[data-share-toast]');
    if (!igBtn || !(igBtn instanceof HTMLButtonElement) || !toast) return;

    var title = igBtn.getAttribute('data-share-episode-title') || '';
    var pageUrl = igBtn.getAttribute('data-share-episode-url') || '';
    var toastTimer = 0;

    function caption() {
      return [title, pageUrl, '', '#RAAKAA', '#podcast'].join('\n');
    }

    function showToast(msg) {
      toast.textContent = msg;
      toast.hidden = false;
      window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(function () {
        toast.textContent = '';
        toast.hidden = true;
      }, 3200);
    }

    function copyCaption(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        return navigator.clipboard.writeText(text).then(function () {
          showToast('Kopioitu! Liitä teksti Instagramiin.');
        });
      }
      return new Promise(function (resolve, reject) {
        var ta = document.createElement('textarea');
        ta.value = text;
        ta.setAttribute('readonly', '');
        ta.style.position = 'absolute';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        try {
          document.execCommand('copy');
          document.body.removeChild(ta);
          showToast('Kopioitu! Liitä teksti Instagramiin.');
          resolve(undefined);
        } catch (e) {
          document.body.removeChild(ta);
          reject(e);
        }
      });
    }

    igBtn.addEventListener('click', function () {
      var text = caption();

      if (navigator.share) {
        navigator
          .share({ title: title, text: text })
          .then(function () {
            showToast('Valmis!');
          })
          .catch(function (err) {
            if (err && err.name === 'AbortError') return;
            copyCaption(text).catch(function () {});
          });
      } else {
        copyCaption(text).catch(function () {});
      }
    });
  })();
</script>

<script>
  (function () {
    var root = document.getElementById('episode-share');
    if (!root) return;
    var btn = root.querySelector('[data-embed-copy]');
    var ta = root.querySelector('.embed-snippet');
    var toast = root.querySelector('[data-embed-toast]');
    if (!btn || !ta || !(ta instanceof HTMLTextAreaElement) || !toast) return;

    var t = 0;
    btn.addEventListener('click', function () {
      var text = ta.value;
      function show() {
        toast.textContent = 'Kopioitu!';
        toast.hidden = false;
        window.clearTimeout(t);
        t = window.setTimeout(function () {
          toast.textContent = '';
          toast.hidden = true;
        }, 2600);
      }
      function fallback() {
        ta.focus();
        ta.select();
        try {
          document.execCommand('copy');
          show();
        } catch (_) {}
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(show).catch(fallback);
      } else {
        fallback();
      }
    });
  })();
</script>

<style>
  .episode-share {
    position: relative;
    margin: 1.25rem 0 1.5rem;
  }

  .share-label {
    margin: 0 0 0.55rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .share-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.55rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    color: var(--text);
    text-decoration: none;
    cursor: pointer;
    transition:
      background 150ms ease,
      border-color 150ms ease,
      color 150ms ease,
      transform 150ms ease,
      box-shadow 150ms ease;
  }

  .share-btn:hover {
    background: rgba(255, 212, 0, 0.1);
    border-color: rgba(255, 212, 0, 0.35);
    color: var(--accent);
  }

  .share-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .share-btn:active {
    transform: scale(0.96);
  }

  .share-copy {
    position: relative;
  }

  .share-copy.is-copied {
    background: rgba(52, 199, 89, 0.15);
    border-color: rgba(52, 199, 89, 0.45);
    color: #6ee7a8;
  }

  .share-copy.is-copied:hover {
    color: #6ee7a8;
    border-color: rgba(52, 199, 89, 0.55);
  }

  .share-copy__idle,
  .share-copy__done {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .share-copy__done:not([hidden]) {
    display: flex;
  }

  .share-embed {
    flex: 0 0 auto;
  }

  .share-embed[open] {
    flex: 1 1 100%;
    width: 100%;
    position: relative;
    z-index: 5;
  }

  .share-embed__summary {
    list-style: none;
    margin: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    padding: 0;
    gap: 0;
  }

  .share-embed__label {
    display: none;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  @media (min-width: 768px) {
    .share-embed__summary {
      width: auto;
      min-width: 2.75rem;
      padding: 0 0.9rem 0 0.7rem;
      gap: 0.4rem;
      justify-content: flex-start;
    }

    .share-embed__label {
      display: inline;
    }
  }

  .share-embed__summary::-webkit-details-marker {
    display: none;
  }

  .share-embed__panel {
    position: relative;
    margin-top: 0.55rem;
    padding: 0.85rem 1rem 1rem;
    text-align: left;
  }

  .embed-label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .embed-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: flex-start;
    margin-top: 0.25rem;
  }

  .embed-snippet {
    flex: 1 1 220px;
    min-height: 7.5rem;
    margin: 0;
    padding: 0.75rem 0.85rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--text);
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid var(--border);
    border-radius: 10px;
    resize: vertical;
  }

  .embed-snippet:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .embed-copy {
    flex: 0 0 auto;
    align-self: stretch;
    white-space: nowrap;
    justify-content: center;
  }

  .embed-actions {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex: 0 0 auto;
    align-self: flex-start;
    min-width: min(100%, 11rem);
  }

  .embed-demo {
    white-space: nowrap;
    justify-content: center;
    font-size: 0.8rem;
    padding: 0.6rem 1rem;
  }

  .embed-hint {
    margin: 0.6rem 0 0;
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .embed-copy-toast {
    margin: 0.55rem 0 0;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent);
  }

  .embed-copy-toast[hidden] {
    display: none !important;
  }

  .muted {
    color: var(--muted);
  }

  .share-toast {
    position: absolute;
    left: 0;
    top: calc(100% + 0.35rem);
    bottom: auto;
    padding: 0.38rem 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text);
    background: rgba(20, 20, 20, 0.95);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: var(--shadow);
    pointer-events: none;
    z-index: 2;
  }

  .share-toast[hidden] {
    display: none !important;
  }
</style>
