---
type AdminEpisode = {
  slug: string;
  title: string;
  summary: string;
  guestName: string;
  guestRole: string;
  guestBio: string;
  guestImage: string;
  youtubeUrl: string;
  transcriptText: string;
  transcriptPath: string;
  transcriptFormat: string;
  tags: string;
  pdfUrl: string;
};

type Props = {
  episodes: AdminEpisode[];
};

const { episodes } = Astro.props;
---

<section class="admin-wrap">
  <aside class="list-pane">
    <div class="list-head">
      <h1>Episode Admin</h1>
    </div>
    <p class="muted">
      This panel edits manual data only. RSS-derived fields (title/date/audio/image) are read from RSS.com.
    </p>
    <ul id="episode-list" class="episode-list"></ul>
  </aside>

  <section class="editor-pane">
    <form id="episode-form">
      <h2 id="editor-title">Select an episode</h2>
      <p class="muted">All saved fields below are reflected on live `/jaksot` pages.</p>

      <fieldset>
        <legend>Basic Info</legend>
        <label>Title (from RSS)<input name="title" type="text" readonly /></label>
        <small>Read-only, pulled automatically from RSS.com.</small>
        <label>Slug (from RSS)<input name="slug" type="text" readonly /></label>
        <small>Read-only route key. Must match RSS episode slug.</small>
        <label>Short description / summary<textarea name="summary" rows="3"></textarea></label>
        <small>Shown in episode cards as the summary text.</small>
      </fieldset>

      <fieldset>
        <legend>Guest Details</legend>
        <label>Guest name<input name="guestName" type="text" /></label>
        <small>Name shown on episode and guest pages.</small>
        <label>Guest title / role<input name="guestRole" type="text" /></label>
        <small>Role shown on the guest page card/details.</small>
        <label>Guest bio<textarea name="guestBio" rows="4"></textarea></label>
        <small>Long-form guest bio text for guest pages.</small>
        <label>Guest photo URL or local file path<input name="guestImage" type="text" /></label>
        <small>Example: /images/vieraat/guest.png</small>
      </fieldset>

      <fieldset>
        <legend>Media</legend>
        <label>YouTube URL<input name="youtubeUrl" type="url" /></label>
        <small>Accepted: youtu.be, watch?v=, /embed/.</small>
        <img id="yt-preview" class="yt-preview" alt="YouTube preview thumbnail" hidden />
        <label>PDF transcript URL<input name="pdfUrl" type="text" /></label>
        <small>Used by the Litterointi/PDF action button.</small>
      </fieldset>

      <fieldset>
        <legend>Transcript</legend>
        <p id="transcript-format" class="format-pill">Current format: unknown</p>
        <label>Raw transcript text<textarea name="transcriptText" rows="10"></textarea></label>
        <small>Saved to markdown file for this episode transcript.</small>
        <label>Transcript file path<input name="transcriptPath" type="text" /></label>
        <small>Kept under src/content/transcripts/*.md</small>
      </fieldset>

      <fieldset>
        <legend>Metadata / SEO</legend>
        <label>Tags<input name="tags" type="text" /></label>
        <small>Comma-separated tags shown as topic chips.</small>
      </fieldset>

      <div class="actions">
        <button id="save-btn" type="submit">Save</button>
      </div>
      <p id="status" class="status" role="status" aria-live="polite"></p>
    </form>
  </section>
</section>

<script define:vars={{ episodes }} type="module">
  const listEl = document.getElementById('episode-list');
  const form = document.getElementById('episode-form');
  const statusEl = document.getElementById('status');
  const titleEl = document.getElementById('editor-title');
  const formatEl = document.getElementById('transcript-format');
  const ytPreview = document.getElementById('yt-preview');
  const youtubeInput = form.elements.namedItem('youtubeUrl');

  let rows = Array.isArray(episodes) ? [...episodes] : [];
  let activeSlug = rows[0]?.slug ?? null;

  function getYoutubeId(url) {
    if (!url) return null;
    try {
      const parsed = new URL(url);
      if (parsed.hostname === 'youtu.be') return parsed.pathname.split('/').filter(Boolean)[0] || null;
      if (parsed.hostname.includes('youtube.com')) {
        if (parsed.pathname === '/watch') return parsed.searchParams.get('v');
        if (parsed.pathname.startsWith('/embed/')) return parsed.pathname.split('/').filter(Boolean)[1] || null;
      }
    } catch {
      return null;
    }
    return null;
  }

  function setStatus(message, isError = false) {
    statusEl.textContent = message;
    statusEl.classList.toggle('error', isError);
  }

  function selectedRow() {
    return rows.find((r) => r.slug === activeSlug) || null;
  }

  function renderList() {
    listEl.innerHTML = '';
    rows
      .slice()
      .sort((a, b) => a.slug.localeCompare(b.slug))
      .forEach((row) => {
        const li = document.createElement('li');
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = row.slug === activeSlug ? 'item active' : 'item';
        btn.textContent = `${row.title || '(Untitled)'} (${row.slug})`;
        btn.addEventListener('click', () => {
          activeSlug = row.slug;
          fillForm();
          renderList();
        });
        li.appendChild(btn);
        listEl.appendChild(li);
      });
  }

  function fillForm() {
    const row = selectedRow();
    if (!row) return;
    titleEl.textContent = `Editing: ${row.title || row.slug}`;
    Object.entries(row).forEach(([key, value]) => {
      const field = form.elements.namedItem(key);
      if (field) field.value = value ?? '';
    });
    formatEl.textContent = `Current format: ${row.transcriptFormat || 'none'}`;
    updateYoutubePreview();
  }

  function readForm() {
    return {
      title: String(form.elements.namedItem('title').value || '').trim(),
      slug: String(form.elements.namedItem('slug').value || '').trim(),
      summary: String(form.elements.namedItem('summary').value || '').trim(),
      guestName: String(form.elements.namedItem('guestName').value || '').trim(),
      guestRole: String(form.elements.namedItem('guestRole').value || '').trim(),
      guestBio: String(form.elements.namedItem('guestBio').value || '').trim(),
      guestImage: String(form.elements.namedItem('guestImage').value || '').trim(),
      youtubeUrl: String(form.elements.namedItem('youtubeUrl').value || '').trim(),
      transcriptText: String(form.elements.namedItem('transcriptText').value || ''),
      transcriptPath: String(form.elements.namedItem('transcriptPath').value || '').trim(),
      transcriptFormat: String(form.elements.namedItem('transcriptFormat')?.value || 'markdown file').trim(),
      tags: String(form.elements.namedItem('tags').value || '').trim(),
      pdfUrl: String(form.elements.namedItem('pdfUrl').value || '').trim(),
    };
  }

  async function saveEpisode(payload, mode, previousSlug = null) {
    const episodeRes = await fetch('/api/save-episode', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mode, previousSlug, episode: payload }),
    });
    if (!episodeRes.ok) {
      const body = await episodeRes.json().catch(() => ({}));
      throw new Error(body.error || 'Failed to save episode metadata.');
    }

    const transcriptRes = await fetch('/api/save-transcript', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        mode: 'save',
        slug: payload.slug,
        title: payload.title,
        summary: payload.summary,
        transcriptText: payload.transcriptText,
        transcriptPath: payload.transcriptPath,
      }),
    });
    if (!transcriptRes.ok) {
      const body = await transcriptRes.json().catch(() => ({}));
      throw new Error(body.error || 'Failed to save transcript file.');
    }
  }

  function updateYoutubePreview() {
    const id = getYoutubeId(youtubeInput.value);
    if (!id) {
      ytPreview.hidden = true;
      ytPreview.removeAttribute('src');
      return;
    }
    ytPreview.src = `https://img.youtube.com/vi/${id}/hqdefault.jpg`;
    ytPreview.hidden = false;
  }

  youtubeInput.addEventListener('input', updateYoutubePreview);

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const prev = selectedRow();
    if (!prev) return;
    const payload = readForm();

    try {
      setStatus('Saving...');
      await saveEpisode(payload, 'upsert', prev.slug);
      rows = rows.map((r) => (r.slug === prev.slug ? payload : r));
      activeSlug = payload.slug;
      renderList();
      fillForm();
      setStatus('Saved successfully.');
    } catch (error) {
      setStatus(error instanceof Error ? error.message : 'Save failed.', true);
    }
  });

  renderList();
  if (activeSlug) fillForm();
</script>

<style>
  .admin-wrap {
    width: min(1200px, 94vw);
    margin: 7rem auto 2rem;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 1rem;
  }
  .list-pane,
  .editor-pane {
    background: #101114;
    border: 1px solid #2b2d31;
    border-radius: 14px;
    padding: 1rem;
  }
  .list-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.8rem;
  }
  .list-head h1 {
    margin: 0;
    font-size: 1.1rem;
  }
  button {
    background: #2c62ff;
    color: #fff;
    border: 0;
    border-radius: 8px;
    padding: 0.55rem 0.8rem;
    cursor: pointer;
    font: inherit;
  }
  .episode-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }
  .item {
    width: 100%;
    text-align: left;
    background: #1a1d22;
    border: 1px solid #31343a;
    padding: 0.5rem 0.65rem;
  }
  .item.active {
    background: #223252;
    border-color: #2f5fca;
  }
  form {
    display: grid;
    gap: 0.9rem;
  }
  fieldset {
    border: 1px solid #2f333a;
    border-radius: 10px;
    padding: 0.85rem;
    display: grid;
    gap: 0.5rem;
  }
  legend {
    padding: 0 0.3rem;
    color: #d0d5e0;
    font-weight: 700;
    font-size: 0.95rem;
  }
  label {
    display: grid;
    gap: 0.3rem;
    font-size: 0.92rem;
  }
  input,
  textarea {
    background: #16181d;
    color: #f0f3f8;
    border: 1px solid #31343a;
    border-radius: 8px;
    padding: 0.55rem 0.65rem;
    font: inherit;
  }
  small {
    color: #a8adb8;
    margin-top: -0.1rem;
  }
  .actions {
    display: flex;
    gap: 0.6rem;
  }
  .status {
    margin: 0;
    color: #93df9d;
    min-height: 1.25rem;
  }
  .status.error {
    color: #ff8b8b;
  }
  .muted {
    margin: -0.4rem 0 0.3rem;
    color: #a8adb8;
  }
  .yt-preview {
    display: block;
    width: min(280px, 100%);
    border-radius: 8px;
    border: 1px solid #31343a;
    margin: 0.2rem 0;
  }
  .format-pill {
    margin: 0;
    color: #c6cbda;
    font-size: 0.84rem;
    background: #1b1e24;
    border: 1px solid #2f333a;
    border-radius: 999px;
    padding: 0.25rem 0.65rem;
    width: fit-content;
  }
  @media (max-width: 980px) {
    .admin-wrap {
      grid-template-columns: 1fr;
    }
  }
</style>
