---
import EpisodeButtons from './EpisodeButtons.astro';
import { formatFinnishDate, type Episode } from '../lib/rss';
import { formatDuration, getEpisodeMeta, resolveGuestNames } from '../lib/episodeMeta';

type Props = {
  episode: Episode;
  pdfUrl?: string | null;
  headingLevel?: 'h2' | 'h3';
};

const { episode, pdfUrl = null, headingLevel = 'h3' } = Astro.props;

const meta = getEpisodeMeta(episode);
const duration = formatDuration(episode.duration);
const guests = resolveGuestNames(meta.guests ?? []);
const topics = meta.topics ?? [];

const stripHtml = (value: string) => value.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const description = meta.summary || stripHtml(episode.description);
const Heading = headingLevel;

const searchString = [
  episode.title,
  description,
  guests.map((g) => g.name).join(' '),
  topics.join(' '),
].join(' ').toLowerCase();
---

<article
  class="ep glass"
  data-episode-card
  data-search={searchString}
  data-topics={topics.join('|')}
  data-guests={guests.map((g) => g.slug).join('|')}
>
  <a class="cover-wrap" href={`/jaksot/${episode.slug}`} aria-label={`Avaa jakso: ${episode.title}`}>
    {episode.imageUrl && (
      <img
        src={episode.imageUrl}
        alt={episode.title}
        loading="lazy"
        decoding="async"
        width="600"
        height="600"
      />
    )}
  </a>

  <div class="meta-row">
    <span class="date">{formatFinnishDate(episode.publishedAt)}</span>
    {duration && <span class="duration" aria-label={`Kesto ${duration}`}>{duration}</span>}
  </div>

  <Heading class="ep-title"><a href={`/jaksot/${episode.slug}`}>{episode.title}</a></Heading>

  {guests.length > 0 && (
    <p class="guests">
      <span class="label">Vieras{guests.length === 1 ? '' : 'sat'}:</span>
      {guests.map((g, i) => (
        <span>
          <a href={`/vieraat/${g.slug}`}>{g.name}</a>{i < guests.length - 1 ? ', ' : ''}
        </span>
      ))}
    </p>
  )}

  <p class="desc">{description.slice(0, 160)}{description.length > 160 ? '…' : ''}</p>

  {topics.length > 0 && (
    <ul class="topics" aria-label="Aiheet">
      {topics.map((t) => <li class="topic">#{t}</li>)}
    </ul>
  )}

  <EpisodeButtons
    slug={episode.slug}
    title={episode.title}
    audioUrl={episode.audioUrl}
    pdfUrl={pdfUrl}
  />
</article>

<style>
  .ep {
    padding: 0.85rem;
    transition: border-color 180ms ease;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    contain: layout paint;
  }

  .ep:hover {
    border-color: rgba(255, 212, 0, 0.4);
  }

  .cover-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    margin-bottom: 0.4rem;
    display: block;
    border-radius: 12px;
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    transition: filter 280ms ease, transform 320ms ease;
    display: block;
  }

  .ep:hover .cover-wrap img,
  .ep:focus-within .cover-wrap img {
    filter: grayscale(0);
    transform: scale(1.04);
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    font-weight: 700;
    margin: 0;
  }

  .date {
    color: var(--accent);
  }

  .duration {
    color: var(--muted);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.08em;
  }

  .ep-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .ep-title a {
    transition: color 150ms ease;
  }

  .ep-title a:hover {
    color: var(--accent);
  }

  .guests {
    margin: 0;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .guests .label {
    color: var(--text);
    font-weight: 600;
    margin-right: 0.35rem;
  }

  .guests a {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .desc {
    color: var(--muted);
    margin: 0;
    line-height: 1.5;
    font-size: 0.92rem;
  }

  .topics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .topic {
    font-size: 0.72rem;
    color: var(--muted);
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.04);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    letter-spacing: 0.04em;
  }
</style>
